<%- include('partials/header', { title: community.name }) %>
<%- include('partials/navbar') %>

<main class="page-container" style="max-width: 1300px;">
    <h1 class="title"><%= community.name %></h1>

    <div class="card" style="margin-bottom: 25px; text-align: left; align-items: stretch; padding: 20px;">
        <p style="margin-bottom: 6px; color: var(--text);"><b>Target Disease Spec:</b> <span style="background: rgba(79, 70, 229, 0.05); padding: 2px 8px; border-radius: 4px; font-weight: 700;"><%= community.disease %></span></p>
        <p style="margin: 0; color: var(--text-muted);"><%= community.description %></p>
        <div>
            <a href="/communities" class="btn-danger-outline" style="display: inline-block; margin-top: 15px; padding: 8px 16px; font-size: 0.85rem; text-decoration: none;">⬅ Back to Support Groups</a>
        </div>
    </div>

    <!-- SPLIT LAYOUT -->
    <div class="appointment-layout">
        
        <!-- LEFT COLUMN: POSTS FEED -->
        <div class="post-feed-section">
            <!-- CREATE POST -->
            <h2 style="text-align: left; margin-bottom: 15px;">Create Post</h2>

            <form action="/api/posts" method="POST" class="form-card" style="margin-bottom: 30px; text-align: left;">
                <input type="hidden" name="community" value="<%= community._id %>">
                <input type="hidden" name="disease" value="<%= community.disease %>">

                <div class="form-group">
                    <label for="post-title" style="text-align: left;">Post Title</label>
                    <input type="text" name="title" id="post-title" placeholder="What is on your mind?" required>
                </div>

                <div class="form-group">
                    <label for="post-content" style="text-align: left;">Post Content</label>
                    <textarea name="content" id="post-content" placeholder="Share your experience, query, or advice..." required style="min-height: 100px;"></textarea>
                </div>

                <button type="submit" class="btn-primary" style="align-self: flex-start; min-width: unset;">Post Message</button>
            </form>

            <!-- POSTS DISCUSSION FEED -->
            <h2 style="text-align: left; margin-bottom: 15px;">Posts Discussion Feed</h2>

            <div id="posts-container">
                <% if (!posts || posts.length === 0) { %>
                    <div class="empty-state">
                        <span class="empty-icon">💬</span>
                        <h3>No Posts Yet</h3>
                        <p>No messages have been posted in this community yet. Be the first to share your experience!</p>
                    </div>
                <% } else { %>
                    <% posts.forEach(post => { %>
                        <div class="card" data-id="<%= post._id %>" style="margin-bottom: 20px; text-align: left; align-items: stretch; padding: 20px;">
                            <h3 style="text-align: left; font-size: 1.15rem; margin-bottom: 8px;"><%= post.title %></h3>
                            <p style="color: var(--text); font-size: 0.95rem; margin-bottom: 12px;"><%= post.content %></p>

                            <div style="display: flex; gap: 15px; font-size: 0.82rem; color: var(--text-muted); margin-bottom: 15px; flex-wrap: wrap;">
                                <span><b>Author:</b> <%= post.author?.username || 'Anonymous' %></span>
                                <span><b>Status:</b> 
                                    <span class="status status-<%= post.status.toLowerCase() %>" style="font-weight: 700;">
                                        <%= post.status %>
                                    </span>
                                </span>
                                <% if (post.aiReason) { %>
                                    <span style="font-style: italic;"><b>AI Verdict Note:</b> <%= post.aiReason %></span>
                                <% } %>
                            </div>

                            <div style="display: flex; align-items: center; gap: 15px; flex-wrap: wrap; border-top: 1px solid var(--line); padding-top: 12px;">
                                <!-- LIKE BUTTON -->
                                <form action="/api/posts/like/<%= post._id %>" method="POST" style="margin:0; width: auto; display: inline-flex;">
                                    <button type="submit" class="btn-primary" style="padding: 6px 12px; font-size: 0.82rem; min-width: unset;">
                                        👍 Like (<span class="like-count"><%= post.likes.length %></span>)
                                    </button>
                                </form>

                                <!-- COMMENT FORM -->
                                <form action="/api/comments" method="POST" style="margin:0; flex: 1; display: inline-flex; gap: 10px; flex-wrap: nowrap; background: transparent; border: none; box-shadow: none; padding: 0;">
                                    <input type="hidden" name="postId" value="<%= post._id %>">
                                    <input type="text" name="content" placeholder="Comment..." required style="padding: 6px 10px; font-size: 0.82rem; flex: 1; min-width: 100px;">
                                    <button type="submit" class="btn-success" style="padding: 6px 12px; font-size: 0.82rem; min-width: unset; margin: 0;">Send</button>
                                </form>
                            </div>

                            <!-- COMMENTS -->
                            <div class="comments" style="margin-top: 12px; padding-top: 12px; border-top: 1px dashed var(--line);">
                                <% if (post.comments && post.comments.length > 0) { %>
                                    <% post.comments.forEach(c => { %>
                                        <p style="margin: 4px 0; border-bottom: 1px solid #f8fafc; padding-bottom: 4px; font-size: 0.88rem;">
                                            <b><%= c.author?.username || 'Anonymous' %>:</b>
                                            <%= c.content %>
                                        </p>
                                    <% }) %>
                                <% } else { %>
                                    <p class="no-comments" style="font-style: italic; font-size: 0.82rem; margin: 0; color: var(--text-muted);">No comments yet</p>
                                <% } %>
                            </div>
                        </div>
                    <% }) %>
                <% } %>
            </div>
        </div>

        <!-- RIGHT COLUMN: COMMUNITY LIVE CHATROOM -->
        <div class="community-chat-section">
            <h2 style="text-align: left; margin-bottom: 15px;">💬 Live Group Chat</h2>
            
            <div class="card" style="padding: 0; align-items: stretch; border-radius: var(--radius-lg); overflow: hidden; height: 600px; display: flex; flex-direction: column;">
                
                <!-- Chat Window -->
                <div id="comm-messages" style="flex: 1; padding: 16px; overflow-y: auto; background: #f8fafc; display: flex; flex-direction: column; gap: 8px;">
                    <!-- Dynamically populated -->
                </div>

                <!-- Chat Input Form -->
                <div style="padding: 12px; background: white; border-top: 1px solid var(--line); display: flex; gap: 8px;">
                    <input 
                        type="text" 
                        id="comm-text" 
                        placeholder="Type a group message..." 
                        style="flex: 1; font-size: 0.88rem; border-radius: var(--radius); padding: 8px 12px; border: 1px solid #cbd5e1;"
                        onkeypress="handleCommKeyPress(event)"
                        autocomplete="off"
                    />
                    <button 
                        id="comm-send-btn" 
                        class="btn-primary" 
                        style="padding: 8px 16px; margin: 0; font-size: 0.88rem; min-width: unset;" 
                        onclick="sendCommMessage()"
                    >
                        Send
                    </button>
                </div>
            </div>
        </div>

    </div>

    <!-- SOCKET REAL-TIME -->
    <script src="/socket.io/socket.io.js"></script>

    <script>
        const socket = io();
        const communityId = "<%= community._id %>";
        const commRoomId = "community_" + communityId;
        const currentUserId = "<%= user.id %>";

        const commMessagesContainer = document.getElementById("comm-messages");
        const commInput = document.getElementById("comm-text");
        const container = document.getElementById("posts-container");

        // -----------------------------
        // COMMUNITY CHAT LOGIC (NEW)
        // -----------------------------

        // Join community chat room
        socket.emit("join-room", commRoomId);

        // Load community chat history on mount
        fetch(`/chat/community/${communityId}`)
            .then(res => res.json())
            .then(messages => {
                commMessagesContainer.innerHTML = "";
                if (messages.length === 0) {
                    commMessagesContainer.innerHTML = `
                        <div id="no-comm-msg" style="margin: auto; text-align: center; color: var(--text-muted); font-size: 0.85rem; padding: 20px;">
                            <b>Welcome to the Live Room!</b><br>Messages are instant and real-time. Say hi!
                        </div>
                    `;
                } else {
                    messages.forEach(msg => appendCommMessage(msg));
                }
                scrollToCommBottom();
            })
            .catch(err => console.error("Error loading chat history:", err));

        // Scroll chat to bottom
        function scrollToCommBottom() {
            commMessagesContainer.scrollTop = commMessagesContainer.scrollHeight;
        }

        // Send a community message
        function sendCommMessage() {
            const text = commInput.value.trim();
            if (!text) return;

            socket.emit("send-message", {
                roomId: commRoomId,
                content: text,
                communityId: communityId
            });

            commInput.value = "";
            commInput.focus();
        }

        function handleCommKeyPress(e) {
            if (e.key === "Enter") {
                sendCommMessage();
            }
        }

        // Render received message
        function appendCommMessage(msg) {
            const noMsgPrompt = document.getElementById("no-comm-msg");
            if (noMsgPrompt) noMsgPrompt.remove();

            const isMe = msg.sender._id.toString() === currentUserId.toString();
            const div = document.createElement("div");
            div.style.display = "flex";
            div.style.flexDirection = "column";
            div.style.alignItems = isMe ? "flex-end" : "flex-start";
            div.style.marginBottom = "8px";

            const nameSpan = document.createElement("span");
            nameSpan.style.fontSize = "0.7rem";
            nameSpan.style.fontWeight = "700";
            nameSpan.style.color = "var(--text-muted)";
            nameSpan.style.marginBottom = "2px";
            nameSpan.innerText = msg.sender.username + (msg.sender.role === 'doctor' ? ' (Doctor 🩺)' : '');

            const bubble = document.createElement("div");
            bubble.style.padding = "8px 12px";
            bubble.style.borderRadius = "10px";
            bubble.style.fontSize = "0.85rem";
            bubble.style.lineHeight = "1.35";
            bubble.style.maxWidth = "85%";
            bubble.style.wordBreak = "break-word";
            bubble.style.boxShadow = "var(--shadow-soft)";

            if (isMe) {
                bubble.style.background = "var(--blue)";
                bubble.style.color = "white";
                bubble.style.borderTopRightRadius = "2px";
            } else {
                bubble.style.background = msg.sender.role === 'doctor' ? '#e0f2fe' : 'white';
                bubble.style.color = "var(--text)";
                bubble.style.border = "1px solid var(--line)";
                bubble.style.borderTopLeftRadius = "2px";
            }
            bubble.innerText = msg.content;

            div.appendChild(nameSpan);
            div.appendChild(bubble);
            commMessagesContainer.appendChild(div);
            scrollToCommBottom();
        }

        // -----------------------------
        // POSTS & COMMENTS SOCKET LOGIC
        // -----------------------------

        // Listen for new posts
        socket.on("new-post", (post) => {
            const emptyState = container.querySelector(".empty-state");
            if (emptyState) {
                emptyState.remove();
            }

            const div = document.createElement("div");
            div.classList.add("card");
            div.style.marginBottom = "20px";
            div.style.textAlign = "left";
            div.style.alignItems = "stretch";
            div.style.padding = "20px";
            div.setAttribute("data-id", post._id);

            div.innerHTML = `
                <h3 style="text-align: left; font-size: 1.15rem; margin-bottom: 8px;">${post.title}</h3>
                <p style="color: var(--text); font-size: 0.95rem; margin-bottom: 12px;">${post.content}</p>
                <div style="display: flex; gap: 15px; font-size: 0.82rem; color: var(--text-muted); margin-bottom: 15px; flex-wrap: wrap;">
                    <span><b>Author:</b> ${post.author?.username || "User"}</span>
                    <span><b>Status:</b> <span class="status status-${post.status.toLowerCase()}" style="font-weight: 700;">${post.status}</span></span>
                </div>

                <div style="display: flex; align-items: center; gap: 15px; flex-wrap: wrap; border-top: 1px solid var(--line); padding-top: 12px;">
                    <form action="/api/posts/like/${post._id}" method="POST" style="margin:0; width: auto; display: inline-flex;">
                        <button type="submit" class="btn-primary" style="padding: 6px 12px; font-size: 0.82rem; min-width: unset;">
                            👍 Like (<span class="like-count">0</span>)
                        </button>
                    </form>

                    <form action="/api/comments" method="POST" style="margin:0; flex: 1; display: inline-flex; gap: 10px; flex-wrap: nowrap; background: transparent; border: none; box-shadow: none; padding: 0;">
                        <input type="hidden" name="postId" value="${post._id}">
                        <input type="text" name="content" placeholder="Comment..." required style="padding: 6px 10px; font-size: 0.82rem; flex: 1; min-width: 100px;">
                        <button type="submit" class="btn-success" style="padding: 6px 12px; font-size: 0.82rem; min-width: unset; margin: 0;">Send</button>
                    </form>
                </div>

                <div class="comments" style="margin-top: 12px; padding-top: 12px; border-top: 1px dashed var(--line);">
                    <p class="no-comments" style="font-style: italic; font-size: 0.82rem; margin: 0; color: var(--text-muted);">No comments yet</p>
                </div>
            `;

            container.prepend(div);
        });

        // Listen for message broadcasts in direct rooms
        socket.on("new-message", (msg) => {
            // If it is sent to this community room, append it!
            if (msg.community && msg.community.toString() === communityId.toString()) {
                appendCommMessage(msg);
            }
        });

        // LIKE UPDATE
        socket.on("post-liked", (data) => {
            const post = document.querySelector(`[data-id="${data.postId}"]`);
            if (post) {
                post.querySelector(".like-count").innerText = data.likes;
            }
        });

        // UNLIKE UPDATE
        socket.on("post-unliked", (data) => {
            const post = document.querySelector(`[data-id="${data.postId}"]`);
            if (post) {
                post.querySelector(".like-count").innerText = data.likes;
            }
        });

        // NEW COMMENT
        socket.on("new-comment", (comment) => {
            const post = document.querySelector(`[data-id="${comment.post}"]`);

            if (post) {
                const box = post.querySelector(".comments");
                const noComments = box.querySelector(".no-comments");
                if (noComments) {
                    noComments.remove();
                }

                const p = document.createElement("p");
                p.style.margin = "4px 0";
                p.style.borderBottom = "1px solid #f8fafc";
                p.style.paddingBottom = "4px";
                p.style.fontSize = "0.88rem";
                p.innerHTML = `<b>${comment.author.username}:</b> ${comment.content}`;

                box.appendChild(p);
            }
        });

        // DELETE COMMENT
        socket.on("delete-comment", (data) => {
            const post = document.querySelector(`[data-id="${data.commentId}"]`);
            if (post) {
                post.remove();
            }
        });

    </script>

</main>

<%- include('partials/footer') %>