<%- include('../includes/header', { title: 'Doctor Dashboard' }) %>
<%- include('../includes/navbar') %>

<main class="page-container">
    <div class="dashboard-header" style="text-align: center; margin-bottom: 40px; margin-top: 20px;">
        <h1 class="title">Doctor Workspace</h1>
        <h2>Welcome, Dr. <%= user?.username %> 🩺</h2>
        <p class="section-desc">Manage medical verification requests and schedule consultations with patients.</p>
    </div>

    <!-- tab selectors -->
    <div class="tabs-container" style="display: flex; justify-content: center; gap: 20px; margin-bottom: 30px;">
        <button id="tab-posts-btn" class="tab-btn active-tab" onclick="switchTab('posts')">📋 Post Verification Queue (<%= posts.length %>)</button>
        <button id="tab-apps-btn" class="tab-btn" onclick="switchTab('apps')">📅 Appointments Hub (<%= appointments.length %>)</button>
    </div>

    <!-- posts moderation tab -->
    <div id="posts-tab" class="tab-content active-content">
        <h2>📋 Pending Verification Queue</h2>
        <p class="section-desc" style="margin-bottom: 25px;">Review medical queries and advice to tag them as Safe, Misleading/Fake, or Suspicious.</p>

        <% if (!posts || posts.length === 0) { %>
            <div class="empty-state">
                <span class="empty-icon">✅</span>
                <h3>Inbox Zero!</h3>
                <p>No medical posts are currently pending review. Thank you for keeping the community safe!</p>
            </div>
        <% } else { %>
            <div class="moderation-list">
                <% posts.forEach(post => { %>
                    <div class="card moderation-card" style="text-align: left; align-items: stretch; margin-bottom: 20px;">
                        <div class="post-details">
                            <h3 style="text-align: left;"><%= post.title %></h3>
                            <p class="post-content" style="color: var(--text); font-style: italic; margin-top: 10px; margin-bottom: 15px; padding: 12px; background: rgba(0, 0, 0, 0.02); border-left: 3px solid var(--blue); border-radius: 4px;">
                                "<%= post.content %>"
                            </p>
                            <p class="post-meta" style="font-size: 0.88rem; color: var(--text-muted); margin-bottom: 15px;">
                                <b>Author:</b> <%= post.author?.username || 'Anonymous' %> &nbsp;|&nbsp; 
                                <b>Target Disease:</b> <span style="background: rgba(79, 70, 229, 0.05); padding: 2px 6px; border-radius: 4px; font-weight: 600;"><%= post.disease %></span>
                            </p>
                        </div>
                        
                        <!-- verify form -->
                        <form action="/api/doctor-posts/review/<%= post._id %>" method="POST" class="moderation-form" style="margin-top: 10px;">
                            <div class="form-group" style="margin-bottom: 12px; width: 100%;">
                                <label for="comment-<%= post._id %>" style="text-align: left; font-weight: 600; font-size: 0.85rem;">Verification Note</label>
                                <input type="text" name="comment" id="comment-<%= post._id %>" placeholder="Add professional verification notes (optional)..." style="width: 100%;">
                            </div>
                            <div class="moderation-actions" style="display: flex; gap: 10px; flex-wrap: wrap;">
                                <button name="status" value="SAFE" class="btn-success" style="flex: 1; min-width: 140px; padding: 8px 16px; font-size: 0.88rem;">✔ Approve (Safe)</button>
                                <button name="status" value="FAKE" class="btn-danger" style="flex: 1; min-width: 140px; padding: 8px 16px; font-size: 0.88rem;">❌ Reject (Fake)</button>
                                <button name="status" value="SUSPICIOUS" class="btn-warning" style="flex: 1; min-width: 140px; padding: 8px 16px; font-size: 0.88rem;">⚠ Tag Suspicious</button>
                            </div>
                        </form>
                    </div>
                <% }) %>
            </div>
        <% } %>
    </div>

    <!-- appointments tab -->
    <div id="apps-tab" class="tab-content">
        <h2>📅 Booked Consultations</h2>
        <p class="section-desc" style="margin-bottom: 25px;">Accept new requests, manage schedule, and launch Telehealth chat sessions with your patients.</p>

        <% if (!appointments || appointments.length === 0) { %>
            <div class="empty-state">
                <span class="empty-icon">📅</span>
                <h3>No Appointments</h3>
                <p>You do not have any patient appointments booked with you yet.</p>
            </div>
        <% } else { %>
            <div class="appointment-grid">
                <% appointments.forEach(app => { %>
                    <div class="card appointment-card" style="text-align: left; align-items: stretch;">
                        <div class="card-header" style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 12px;">
                            <span class="badge status-<%= app.status.toLowerCase() %>"><%= app.status %></span>
                            <span style="font-size: 0.8rem; color: var(--text-muted);">Booked <%= new Date(app.createdAt).toLocaleDateString() %></span>
                        </div>
                        <h3 style="text-align: left; font-size: 1.2rem; margin-bottom: 10px;">Patient: <%= app.patient?.username || 'Anonymous User' %></h3>
                        <p class="app-detail" style="text-align: left; margin-bottom: 8px; font-size: 0.92rem;"><b>Email:</b> <%= app.patient?.email %></p>
                        <p class="app-detail" style="text-align: left; margin-bottom: 8px; font-size: 0.92rem;"><b>Date:</b> <%= app.date %></p>
                        <p class="app-detail" style="text-align: left; margin-bottom: 15px; font-size: 0.92rem;"><b>Time Slot:</b> <%= app.time %></p>

                        <div class="appointment-card-actions" style="display: flex; flex-direction: column; gap: 8px; margin-top: auto;">
                            <% if (app.status === 'PENDING') { %>
                                <div style="display: flex; gap: 10px; width: 100%;">
                                    <form action="/api/doctor-dashboard/accept/<%= app._id %>" method="POST" style="flex: 1; margin: 0; padding: 0; background: transparent; border: none; box-shadow: none;">
                                        <button type="submit" class="btn-success" style="width: 100%; padding: 8px 12px; font-size: 0.85rem; min-width: unset;">Accept</button>
                                    </form>
                                    <form action="/api/doctor-dashboard/reject/<%= app._id %>" method="POST" style="flex: 1; margin: 0; padding: 0; background: transparent; border: none; box-shadow: none;">
                                        <button type="submit" class="btn-danger-outline" style="width: 100%; padding: 8px 12px; font-size: 0.85rem; min-width: unset;">Reject</button>
                                    </form>
                                </div>
                            <% } else if (app.status === 'CONFIRMED') { %>
                                <a href="/chat/appointment/<%= app._id %>" class="btn-primary" style="text-align: center; text-decoration: none; width: 100%; margin: 0; padding: 8px 12px; font-size: 0.85rem; font-weight: 700;">💬 Join Telehealth Chat</a>
                                <form action="/api/doctor-dashboard/reject/<%= app._id %>" method="POST" style="margin: 0; padding: 0; background: transparent; border: none; box-shadow: none;" onsubmit="return confirm('Cancel this consultation?');">
                                    <button type="submit" class="btn-danger-outline" style="width: 100%; padding: 8px 12px; font-size: 0.85rem; min-width: unset;">Cancel Appointment</button>
                                </form>
                            <% } else { %>
                                <span style="text-align: center; color: var(--text-muted); font-style: italic; font-size: 0.85rem; padding: 8px;">Consultation Cancelled / Closed</span>
                            <% } %>
                        </div>
                    </div>
                <% }) %>
            </div>
        <% } %>
    </div>
</main>

<style>
    /* Styling for Tab Buttons */
    .tab-btn {
        background: transparent;
        color: var(--text-muted);
        border: 1px solid var(--line);
        box-shadow: none;
        padding: 10px 20px;
        font-weight: 600;
        font-size: 0.95rem;
        cursor: pointer;
        border-radius: var(--radius);
        transition: all 0.2s ease;
    }
    
    .tab-btn:hover {
        background: rgba(79, 70, 229, 0.05);
        color: var(--blue);
        transform: none;
        box-shadow: none;
    }
    
    .active-tab {
        background: var(--blue) !important;
        color: white !important;
        border-color: var(--blue);
    }
    
    /* Content hiding logic */
    .tab-content {
        display: none;
    }
    
    .active-content {
        display: block;
    }
</style>

<script>
    function switchTab(tabName) {
        // toggle tab contents
        document.getElementById('posts-tab').classList.remove('active-content');
        document.getElementById('apps-tab').classList.remove('active-content');
        
        // toggle active button styling
        document.getElementById('tab-posts-btn').classList.remove('active-tab');
        document.getElementById('tab-apps-btn').classList.remove('active-tab');
        
        if (tabName === 'posts') {
            document.getElementById('posts-tab').classList.add('active-content');
            document.getElementById('tab-posts-btn').classList.add('active-tab');
        } else {
            document.getElementById('apps-tab').classList.add('active-content');
            document.getElementById('tab-apps-btn').classList.add('active-tab');
        }
    }
</script>

<%- include('../includes/footer') %>
