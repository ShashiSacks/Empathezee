<%- include('../includes/header', { title: 'Disease Communities' }) %>
<%- include('../includes/navbar') %>

<main class="page-container" style="max-width: var(--max); margin: 0 auto; padding: 40px 24px;">
    <div style="text-align: center; margin-bottom: 48px; margin-top: 20px;">
        <h1 class="title" style="font-size: 2.2rem; margin-bottom: 8px; font-family: 'Outfit', sans-serif; font-weight: 800; letter-spacing: -1px; color: var(--primary);">👥 Support Communities</h1>
        <p style="color: var(--text-secondary); font-size: 1.05rem; max-width: 600px; margin: 0 auto; line-height: 1.6;">Join disease-based support communities to share discussions, ask questions, and connect with other patients.</p>
    </div>

    <!-- Main communities split pane layout -->
    <div class="communities-split-container">
        
        <!-- Left Side: Communities List (70% width) -->
        <div class="communities-left-list">
            <div style="display: flex; justify-content: space-between; align-items: center; border-bottom: 2px solid var(--line); padding-bottom: 14px;">
                <h2 style="margin: 0; color: var(--primary); font-size: 1.45rem; font-weight: 700; letter-spacing: -0.5px;">Active Support Groups</h2>
            </div>
            
            <% if (!communities || communities.length === 0) { %>
                <div class="empty-state" style="padding: 60px 20px; text-align: center; border: 2px dashed var(--line); border-radius: var(--radius-lg); background: var(--surface);">
                    <span class="empty-icon" style="font-size: 3rem; display: block; margin-bottom: 12px;">👥</span>
                    <h3 style="font-size: 1.25rem; margin-top: 12px; margin-bottom: 6px; font-weight: 700; color: var(--text);">No Communities Found</h3>
                    <p style="color: var(--text-secondary); max-width: 400px; margin: 0 auto; font-size: 0.92rem;">There are no support communities created yet. Be the first to start a group on the right!</p>
                </div>
            <% } else { %>
                <div style="display: flex; flex-direction: column; gap: 20px; width: 100%;">
                    <% communities.forEach((c) => { %>
                        <% 
                           const isRecommended = userDisease && c.disease.toLowerCase().includes(userDisease.toLowerCase());
                        %>
                        <div class="card community-card <%= isRecommended ? 'highlight-card' : '' %>" style="text-align: left; display: flex; flex-direction: column; justify-content: space-between; padding: 24px; box-shadow: var(--shadow-sm); border-radius: var(--radius-lg); background: var(--surface); border: 1.5px solid var(--line); transition: transform 0.2s, box-shadow 0.2s, border-color 0.2s;" onmouseover="this.style.transform='translateY(-3px)'; this.style.boxShadow='var(--shadow-md)'; this.style.borderColor='var(--accent)';" onmouseout="this.style.transform='none'; this.style.boxShadow='var(--shadow-sm)'; this.style.borderColor='var(--line)';">
                            <div>
                                <% if (isRecommended) { %>
                                    <span class="badge recommendation-badge" style="margin-bottom: 12px; align-self: flex-start; display: inline-block;">✨ Matches Your Profile (<%= userDisease %>)</span>
                                <% } %>
                                <h3 style="text-align: left; font-size: 1.25rem; margin-top: 0; color: var(--primary); font-family: 'Outfit', sans-serif; font-weight: 700; line-height: 1.3; margin-bottom: 8px;"><%= c.name %></h3>
                                <p class="community-desc" style="color: var(--text-secondary); font-size: 0.9rem; line-height: 1.5; margin-top: 0; margin-bottom: 16px;"><%= c.description %></p>
                                
                                <div style="display: flex; flex-wrap: wrap; gap: 16px; margin-bottom: 16px; font-size: 0.85rem; color: var(--text-secondary); border-top: 1px solid var(--line-light); padding-top: 12px;">
                                    <div style="display: flex; align-items: center; gap: 6px;">
                                        <b>Target Disease:</b> 
                                        <span style="background: var(--bg-warm); color: var(--primary); padding: 2px 8px; border-radius: var(--radius-sm); font-weight: 600; border: 1px solid var(--line);"><%= c.disease %></span>
                                    </div>
                                    <div style="display: flex; align-items: center; gap: 6px;">
                                        <b>Location:</b> 
                                        <span>📍 <span style="font-weight: 600; color: var(--text);"><%= c.location %></span></span>
                                    </div>
                                    <div style="display: flex; align-items: center; gap: 6px;">
                                        <b>Type:</b> 
                                        <span class="badge" style="background: <%= c.type === 'online' ? 'var(--success-bg)' : 'var(--warning-bg)' %>; color: <%= c.type === 'online' ? 'var(--success)' : 'var(--warning)' %>; padding: 2px 8px; border-radius: var(--radius-sm); font-weight: 700; text-transform: uppercase; font-size: 0.72rem; border: 1px solid <%= c.type === 'online' ? 'var(--success)' : 'var(--warning)' %>1a;">
                                            <%= c.type || 'online' %>
                                        </span>
                                    </div>
                                    <div style="display: flex; align-items: center; gap: 6px;">
                                        <b>Access Fee:</b> 
                                        <span style="font-weight: 700; color: <%= c.paymentType === 'paid' ? 'var(--danger)' : 'var(--success)' %>">
                                            <%= c.paymentType === 'paid' ? `Paid (₹${c.price})` : 'Free 🟢' %>
                                        </span>
                                    </div>
                                </div>
                                <% if (c.type === 'offline') { %>
                                    <div style="background: var(--bg-warm); padding: 8px 12px; border-radius: var(--radius-sm); border: 1px solid var(--line); font-size: 0.8rem; margin-bottom: 16px; display: flex; gap: 16px;">
                                        <div><b>Date:</b> <%= c.meetingDate %></div>
                                        <div><b>Time:</b> <%= c.meetingTime %></div>
                                        <div><b>Place:</b> 📍 <%= c.meetingPlace %></div>
                                    </div>
                                <% } %>
                            </div>

                            <div class="community-actions" style="border-top: 1px solid var(--line-light); padding-top: 12px; margin-top: 4px;">
                                <% if (userCommunities.includes(c._id.toString())) { %>
                                    <div style="display: flex; gap: 12px; width: 100%;">
                                        <form action="/api/communities/<%= c._id %>/leave" method="POST" style="flex: 1; margin: 0; background: transparent; border: none; box-shadow: none; padding: 0;">
                                            <button type="submit" class="btn-danger-outline" style="width: 100%; padding: 8px 12px; font-size: 0.85rem; font-weight: 600; border-radius: var(--radius-sm); cursor: pointer; border: 1.5px solid var(--line);">Leave</button>
                                        </form>
                                        <a href="/community/<%= c._id %>" class="btn-primary" style="flex: 1; padding: 8px 12px; font-size: 0.85rem; font-weight: 600; text-align: center; text-decoration: none; border-radius: var(--radius-sm); display: flex; align-items: center; justify-content: center;">Enter Group</a>
                                    </div>
                                <% } else { %>
                                    <form action="/api/communities/<%= c._id %>/join" method="POST" style="width: 100%; margin: 0; background: transparent; border: none; box-shadow: none; padding: 0;">
                                        <button type="submit" class="btn-success" style="width: 100%; padding: 8px 12px; font-size: 0.85rem; font-weight: 600; border-radius: var(--radius-sm); cursor: pointer; border: none;">Join Community</button>
                                    </form>
                                <% } %>
                            </div>
                        </div>
                    <% }) %>
                </div>
            <% } %>
        </div>

        <!-- Right Side: Create Community Form (30% width - Sticky) -->
        <div class="communities-right-form" id="create-community-section">
            <h2 style="margin-top: 0; color: var(--primary); font-size: 1.3rem; font-weight: 800; letter-spacing: -0.5px; margin-bottom: 20px; text-align: center;">➕ Create Support Group</h2>
            
            <form action="/api/communities" method="POST" class="form-card" style="box-shadow: none; border: none; background: transparent; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 16px;">
                <div class="form-group" style="display: flex; flex-direction: column; gap: 4px;">
                    <label for="name" style="font-weight: 600; font-size: 0.88rem; color: var(--primary);">Community Name</label>
                    <input type="text" name="name" id="name" required placeholder="e.g. Aids support group" style="padding: 9px 12px; border-radius: var(--radius-sm); border: 1.5px solid var(--line); background: var(--bg-warm); font-size: 0.88rem; outline: none;" />
                </div>

                <div class="form-group" style="display: flex; flex-direction: column; gap: 4px;">
                    <label for="disease" style="font-weight: 600; font-size: 0.88rem; color: var(--primary);">Target Disease</label>
                    <input type="text" name="disease" id="disease" required placeholder="e.g. Aids" style="padding: 9px 12px; border-radius: var(--radius-sm); border: 1.5px solid var(--line); background: var(--bg-warm); font-size: 0.88rem; outline: none;" />
                </div>

                <div class="form-group" style="display: flex; flex-direction: column; gap: 4px;">
                    <label for="location" style="font-weight: 600; font-size: 0.88rem; color: var(--primary);">Location / City</label>
                    <input type="text" name="location" id="location" required placeholder="e.g. Global, Bangalore" style="padding: 9px 12px; border-radius: var(--radius-sm); border: 1.5px solid var(--line); background: var(--bg-warm); font-size: 0.88rem; outline: none;" />
                </div>

                <div class="form-group" style="display: flex; flex-direction: column; gap: 4px;">
                    <label for="type" style="font-weight: 600; font-size: 0.88rem; color: var(--primary);">Format / Type</label>
                    <select name="type" id="type" required onchange="toggleEventDetails(this.value)" style="padding: 9px 12px; border-radius: var(--radius-sm); border: 1.5px solid var(--line); background: var(--bg-warm); font-size: 0.88rem; outline: none; font-weight: 500;">
                        <option value="online" selected>Online Discussion</option>
                        <option value="offline">Offline (In-Person Meeting)</option>
                    </select>
                </div>

                <!-- offline schedule details (toggled via js) -->
                <div id="offline-details" style="display: none; border-left: 3px solid var(--warning); padding-left: 12px; margin-bottom: 4px; display: flex; flex-direction: column; gap: 12px;">
                    <div class="form-group" style="display: flex; flex-direction: column; gap: 4px;">
                        <label for="meetingDate" style="font-weight: 600; font-size: 0.85rem; color: var(--primary);">Meeting Date</label>
                        <input type="date" name="meetingDate" id="meetingDate" style="padding: 9px 12px; border-radius: var(--radius-sm); border: 1.5px solid var(--line); background: var(--bg-warm); font-size: 0.85rem; outline: none;" />
                    </div>

                    <div class="form-group" style="display: flex; flex-direction: column; gap: 4px;">
                        <label for="meetingTime" style="font-weight: 600; font-size: 0.85rem; color: var(--primary);">Meeting Time</label>
                        <input type="time" name="meetingTime" id="meetingTime" style="padding: 9px 12px; border-radius: var(--radius-sm); border: 1.5px solid var(--line); background: var(--bg-warm); font-size: 0.85rem; outline: none;" />
                    </div>

                    <div class="form-group" style="display: flex; flex-direction: column; gap: 4px;">
                        <label for="meetingPlace" style="font-weight: 600; font-size: 0.85rem; color: var(--primary);">Meeting Address</label>
                        <input type="text" name="meetingPlace" id="meetingPlace" placeholder="e.g. Kadapa Hospital Hall" style="padding: 9px 12px; border-radius: var(--radius-sm); border: 1.5px solid var(--line); background: var(--bg-warm); font-size: 0.85rem; outline: none;" />
                    </div>
                </div>

                <div class="form-group" style="display: flex; flex-direction: column; gap: 4px;">
                    <label for="paymentType" style="font-weight: 600; font-size: 0.88rem; color: var(--primary);">Payment Access</label>
                    <select name="paymentType" id="paymentType" required onchange="togglePrice(this.value)" style="padding: 9px 12px; border-radius: var(--radius-sm); border: 1.5px solid var(--line); background: var(--bg-warm); font-size: 0.88rem; outline: none; font-weight: 500;">
                        <option value="free" selected>Free</option>
                        <option value="paid">Paid Entry</option>
                    </select>
                </div>

                <!-- paid entry pricing (toggled via js) -->
                <div id="price-details" style="display: none; border-left: 3px solid var(--danger); padding-left: 12px; margin-bottom: 4px;">
                    <div class="form-group" style="display: flex; flex-direction: column; gap: 4px;">
                        <label for="price" style="font-weight: 600; font-size: 0.85rem; color: var(--primary);">Entry Price (₹)</label>
                        <input type="number" name="price" id="price" min="0" step="1" placeholder="e.g. 150" style="padding: 9px 12px; border-radius: var(--radius-sm); border: 1.5px solid var(--line); background: var(--bg-warm); font-size: 0.85rem; outline: none;" />
                    </div>
                </div>

                <div class="form-group" style="display: flex; flex-direction: column; gap: 4px;">
                    <label for="description" style="font-weight: 600; font-size: 0.88rem; color: var(--primary);">Guidelines / Description</label>
                    <textarea name="description" id="description" required placeholder="Outline topics, meeting rules..." style="padding: 9px 12px; border-radius: var(--radius-sm); border: 1.5px solid var(--line); background: var(--bg-warm); font-size: 0.88rem; outline: none; min-height: 80px; font-family: inherit; line-height: 1.4; resize: vertical;"></textarea>
                </div>

                <button type="submit" class="btn-primary-block" style="padding: 10px; font-weight: 700; font-size: 0.9rem; border-radius: var(--radius-sm); border: none; cursor: pointer; margin-top: 6px;">Create Community</button>
            </form>
        </div>
    </div>
</main>

<script>
    function toggleEventDetails(type) {
        const offlineDetails = document.getElementById('offline-details');
        const meetingDate = document.getElementById('meetingDate');
        const meetingTime = document.getElementById('meetingTime');
        const meetingPlace = document.getElementById('meetingPlace');
        if (type === 'offline') {
            offlineDetails.style.setProperty('display', 'flex', 'important');
            meetingDate.required = true;
            meetingTime.required = true;
            meetingPlace.required = true;
        } else {
            offlineDetails.style.setProperty('display', 'none', 'important');
            meetingDate.required = false;
            meetingTime.required = false;
            meetingPlace.required = false;
        }
    }

    function togglePrice(paymentType) {
        const priceDetails = document.getElementById('price-details');
        const price = document.getElementById('price');
        if (paymentType === 'paid') {
            priceDetails.style.display = 'block';
            price.required = true;
        } else {
            priceDetails.style.display = 'none';
            price.required = false;
        }
    }
</script>

<%- include('../includes/footer') %>