<%- include('../includes/header', { title: 'Dashboard' }) %>
<%- include('../includes/navbar') %>

<main class="page-container">

    <!-- Personalized Greeting Banner -->
    <div class="dashboard-greeting animate-fade-up" id="greeting-banner">
        <div style="position: relative; z-index: 2;">
            <p class="greeting-time" id="greeting-time-label">Good morning</p>
            <h1 class="greeting-title">
                Welcome back, <span style="background: var(--grad-primary); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;"><%= user?.username %></span> 👋
            </h1>
            <p class="greeting-subtitle">
                You are signed in as a <strong><%= user?.role %></strong>.
                <% if (user?.disease) { %>
                    Your community: <span style="color: var(--primary); font-weight: 600;"><%= user.disease %></span>
                <% } %>
            </p>
            <div style="display: flex; gap: 10px; flex-wrap: wrap; margin-top: 20px;">
                <a href="/communities" class="btn-primary btn-sm" id="dash-cta-communities">
                    <i class="fa-solid fa-people-group"></i> Find Your Community
                </a>
                <a href="/doctor/search" class="btn-outline btn-sm" id="dash-cta-doctors" style="border-radius: 999px;">
                    <i class="fa-solid fa-user-doctor"></i> Book a Doctor
                </a>
            </div>
        </div>

        <!-- Decorative blob -->
        <div aria-hidden="true" style="
            position: absolute; right: 32px; top: 50%; transform: translateY(-50%);
            width: 120px; height: 120px;
            background: var(--grad-primary);
            border-radius: 50%;
            opacity: 0.08;
            pointer-events: none;
        "></div>
    </div>

    <!-- Quick Stats Row -->
    <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(160px, 1fr)); gap: 16px; margin-bottom: 32px;" aria-label="Health stats overview">
        <div class="card animate-fade-up" style="padding: 20px; text-align: center; animation-delay: 0.05s;">
            <div style="font-size: 1.8rem; margin-bottom: 6px;">👥</div>
            <div style="font-size: 1.25rem; font-weight: 800; color: var(--primary); letter-spacing: -0.02em;">Join a Group</div>
            <div style="font-size: 0.78rem; color: var(--text-secondary); margin-top: 2px;">Connect with peers</div>
        </div>
        <div class="card animate-fade-up" style="padding: 20px; text-align: center; animation-delay: 0.10s;">
            <div style="font-size: 1.8rem; margin-bottom: 6px;">🩺</div>
            <div style="font-size: 1.25rem; font-weight: 800; color: var(--accent-dark); letter-spacing: -0.02em;">Book a Doc</div>
            <div style="font-size: 0.78rem; color: var(--text-secondary); margin-top: 2px;">Expert guidance</div>
        </div>
        <div class="card animate-fade-up" style="padding: 20px; text-align: center; animation-delay: 0.15s;">
            <div style="font-size: 1.8rem; margin-bottom: 6px;">💊</div>
            <div style="font-size: 1.25rem; font-weight: 800; color: var(--secondary-dark); letter-spacing: -0.02em;">Order Meds</div>
            <div style="font-size: 0.78rem; color: var(--text-secondary); margin-top: 2px;">Fast delivery</div>
        </div>
        <div class="card animate-fade-up" style="padding: 20px; text-align: center; animation-delay: 0.20s;">
            <div style="font-size: 1.8rem; margin-bottom: 6px;">🧘</div>
            <div style="font-size: 1.25rem; font-weight: 800; color: var(--warning); letter-spacing: -0.02em;">Wellness</div>
            <div style="font-size: 0.78rem; color: var(--text-secondary); margin-top: 2px;">Mind & body</div>
        </div>
    </div>

    <!-- Main Dashboard Cards -->
    <div class="dashboard-grid" id="dashboard-main-grid">

        <!-- Communities -->
        <div class="dashboard-card animate-fade-up" style="animation-delay: 0.05s;" id="dash-card-communities">
            <div>
                <span class="card-icon" aria-hidden="true">👥</span>
                <h2 style="text-align: left; font-size: 1.2rem; color: var(--text);">Communities</h2>
                <p>Join disease-based support communities, share discussions, and connect with others who truly understand your journey.</p>
            </div>
            <a href="/communities" class="btn-primary btn-sm" style="align-self: flex-start;" id="dash-btn-communities">
                <i class="fa-solid fa-arrow-right" aria-hidden="true"></i> Open Directory
            </a>
        </div>

        <!-- Find Doctors -->
        <div class="dashboard-card animate-fade-up" style="animation-delay: 0.10s; border-top: 3px solid var(--accent);" id="dash-card-doctors">
            <div>
                <span class="card-icon" aria-hidden="true">🩺</span>
                <h2 style="text-align: left; font-size: 1.2rem; color: var(--text);">Find Doctors</h2>
                <p>Locate verified medical specialists nearby using symptom-based location search. Book consultations in seconds.</p>
            </div>
            <a href="/doctor/search" class="btn-teal btn-sm" style="align-self: flex-start; border-radius: 999px;" id="dash-btn-doctors">
                <i class="fa-solid fa-magnifying-glass" aria-hidden="true"></i> Search Directory
            </a>
        </div>

        <!-- Appointments -->
        <div class="dashboard-card animate-fade-up" style="animation-delay: 0.15s; border-top: 3px solid var(--secondary);" id="dash-card-appointments">
            <div>
                <span class="card-icon" aria-hidden="true">📅</span>
                <h2 style="text-align: left; font-size: 1.2rem; color: var(--text);">Appointments</h2>
                <p>Schedule virtual consultations and direct chat sessions with verified doctors at your convenience.</p>
            </div>
            <a href="/appointments-ui" class="btn-success btn-sm" style="align-self: flex-start; border-radius: 999px;" id="dash-btn-appointments">
                <i class="fa-solid fa-calendar-plus" aria-hidden="true"></i> Book Consultation
            </a>
        </div>

        <!-- Medicines -->
        <div class="dashboard-card animate-fade-up" style="animation-delay: 0.20s; border-top: 3px solid var(--warning);" id="dash-card-medicines">
            <div>
                <span class="card-icon" aria-hidden="true">💊</span>
                <h2 style="text-align: left; font-size: 1.2rem; color: var(--text);">Medicine Directory</h2>
                <p>Browse verified medicine catalogs, search drug information, and order prescribed medicines with fast delivery.</p>
            </div>
            <a href="/medicine" class="btn-warning btn-sm" style="align-self: flex-start; border-radius: 999px;" id="dash-btn-medicines">
                <i class="fa-solid fa-pills" aria-hidden="true"></i> Open Catalog
            </a>
        </div>

        <!-- Doctor Panel (only for doctor role) -->
        <% if (user?.role === "doctor") { %>
        <div class="dashboard-card doctor-card animate-fade-up" style="animation-delay: 0.25s;" id="dash-card-doctor-panel">
            <div>
                <span class="card-icon" aria-hidden="true">🏥</span>
                <h2 style="text-align: left; font-size: 1.2rem; color: var(--text);">Doctor Moderation</h2>
                <p>Review reported community posts, verify medical information, view patient consultations, and manage your dashboard.</p>
            </div>
            <a href="/doctor/dashboard" class="btn-gradient btn-sm" style="align-self: flex-start; border-radius: 999px;" id="dash-btn-doctor-panel">
                <i class="fa-solid fa-shield-halved" aria-hidden="true"></i> Open Moderator Panel
            </a>
        </div>
        <% } %>

    </div>

    <!-- Emergency Support Section -->
    <div class="emergency-card animate-fade-up" style="margin-top: 8px; animation-delay: 0.35s;" role="complementary" aria-label="Emergency support">
        <div class="emergency-icon" aria-hidden="true">🚨</div>
        <div style="flex: 1;">
            <h3 style="text-align: left; color: var(--danger); font-size: 1rem; margin-bottom: 4px;">Need Immediate Help?</h3>
            <p style="color: var(--text-secondary); font-size: 0.875rem; margin-bottom: 0; line-height: 1.5;">
                If you are experiencing a medical emergency, please contact emergency services immediately.
            </p>
            <div class="emergency-actions">
                <a href="tel:112" class="btn-danger btn-sm" id="emergency-call-112" aria-label="Call emergency number 112">
                    <i class="fa-solid fa-phone" aria-hidden="true"></i> Call 112
                </a>
                <a href="tel:102" class="btn-outline btn-sm" id="emergency-call-102" style="border-radius:999px; border-color: var(--danger); color: var(--danger);" aria-label="Call ambulance 102">
                    <i class="fa-solid fa-truck-medical" aria-hidden="true"></i> Ambulance 102
                </a>
                <a href="tel:1800111565" class="btn-outline btn-sm" id="emergency-mental-health" style="border-radius:999px;" aria-label="Mental health helpline">
                    <i class="fa-solid fa-brain" aria-hidden="true"></i> Mental Health Helpline
                </a>
            </div>
        </div>
    </div>

</main>

<script>
(function() {
    // Time-based greeting
    const hour = new Date().getHours();
    const greetingEl = document.getElementById('greeting-time-label');
    if (greetingEl) {
        if (hour < 12) greetingEl.textContent = '🌅 Good morning';
        else if (hour < 17) greetingEl.textContent = '☀️ Good afternoon';
        else if (hour < 21) greetingEl.textContent = '🌆 Good evening';
        else greetingEl.textContent = '🌙 Good night';
    }
})();
</script>

<%- include('../includes/footer') %>