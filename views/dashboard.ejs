<%- include('partials/header', { title: 'Dashboard' }) %>
<%- include('partials/navbar') %>

<main class="page-container">
    <div class="dashboard-header" style="text-align: center; margin-bottom: 40px; margin-top: 20px;">
        <h1 class="title" style="margin-left: auto; margin-right: auto; max-width: 600px;">Empathezee Dashboard</h1>
        <h2 style="margin-top: 15px;">Welcome, <%= user?.username %> 👋</h2>
        <p class="section-desc" style="margin-top: 5px;">You are logged in as a <b><%= user?.role %></b>.</p>
    </div>

    <div class="dashboard-grid">

        <!-- communities -->
        <div class="dashboard-card">
            <div>
                <span class="card-icon">👥</span>
                <h3>Communities</h3>
                <p>Join disease-based support communities and share discussions with other patients.</p>
            </div>
            <a href="/communities" class="btn-primary">Open Directory</a>
        </div>

        <!-- find doctors -->
        <div class="dashboard-card">
            <div>
                <span class="card-icon">👨‍⚕️</span>
                <h3>Find Doctors</h3>
                <p>Locate medical specialists nearby using location search based on your symptoms.</p>
            </div>
            <a href="/doctor/search" class="btn-primary">Search Directory</a>
        </div>

        <!-- appointments -->
        <div class="dashboard-card">
            <div>
                <span class="card-icon">📅</span>
                <h3>Appointments</h3>
                <p>Schedule virtual consultations and direct chat sessions with verified doctors.</p>
            </div>
            <a href="/appointments-ui" class="btn-primary">Book Consultation</a>
        </div>

        <!-- medicines -->
        <div class="dashboard-card">
            <div>
                <span class="card-icon">💊</span>
                <h3>Medicine Directory</h3>
                <p>Browse local medicine catalogs or search disease info using Google Custom Search.</p>
            </div>
            <a href="/medicine" class="btn-primary">Open Catalog</a>
        </div>

        <!-- doctor panel (optional for doctor users) -->
        <% if (user?.role === "doctor") { %>
        <div class="dashboard-card doctor-card">
            <div>
                <span class="card-icon">👨‍⚕️</span>
                <h3>Doctor Moderation</h3>
                <p>Review reported forum posts, verify medical facts, and view consult queues.</p>
            </div>
            <a href="/doctor/dashboard" class="btn-primary">Open Moderator Panel</a>
        </div>
        <% } %>

    </div>
</main>

<%- include('partials/footer') %>