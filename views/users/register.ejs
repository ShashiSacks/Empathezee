<%- include('../includes/header', { title: 'Register', bodyClass: 'auth-page' }) %>

<div class="auth-container">

    <!-- left side (form) -->
    <div class="auth-left">
        <div class="auth-left-content">
            <h1 class="title">Register</h1>

            <form action="/api/auth/register" method="POST">

                <input type="text" name="username" placeholder="Username" required />

                <input type="email" name="email" placeholder="Email" required />

                <input type="password" name="password" placeholder="Password" required />

                <input type="number" name="age" placeholder="Age" min="0" max="120" />

                <div class="form-group">
                    <label for="gender">Gender</label>
                    <select name="gender" id="gender" required>
                        <option value="" disabled selected>Select Gender</option>
                        <option value="male">Male</option>
                        <option value="female">Female</option>
                        <option value="other">Rather not to say</option>
                    </select>
                </div>

                <input type="text" name="disease" placeholder="Disease" />

                <!-- cascading location picker -->
                <div class="location-picker">
                    <div class="form-group">
                        <label for="country">Country <span class="optional-tag">(optional)</span></label>
                        <select name="country" id="country">
                            <option value="">Select Country</option>
                        </select>
                    </div>

                    <div class="form-group" id="state-group" style="display: none;">
                        <label for="state">State <span class="optional-tag">(optional)</span></label>
                        <select id="state">
                            <option value="">Select State</option>
                        </select>
                        <input type="text" id="state-input" placeholder="Type State" style="display: none;" />
                    </div>

                    <div class="form-group" id="district-group" style="display: none;">
                        <label for="district">District <span class="optional-tag">(optional)</span></label>
                        <select id="district">
                            <option value="">Select District</option>
                        </select>
                        <input type="text" id="district-input" placeholder="Type District" style="display: none;" />
                    </div>

                    <div class="form-group" id="city-group" style="display: none;">
                        <label for="city">City / Place <span class="optional-tag">(optional)</span></label>
                        <select id="city">
                            <option value="">Select City</option>
                        </select>
                        <input type="text" id="city-input" placeholder="Type City / Place" style="display: none;" />
                    </div>
                </div>

                <button type="submit">Create Account</button>

            </form>

            <p>
                Already have an account?
                <a href="/login">Login here</a>
            </p>

            <p>
                Registering as a doctor?
                <a href="/doctor/register">Doctor registration</a>
            </p>

            <!-- google login button -->
            <div style="margin-top: 20px; display: flex; flex-direction: column; align-items: center; width: 100%;">
                <div style="width: 100%; display: flex; align-items: center; margin-bottom: 15px; color: var(--text-muted); font-size: 0.8rem;">
                    <div style="flex: 1; height: 1px; background: var(--line);"></div>
                    <span style="padding: 0 10px; font-weight: 550; text-transform: uppercase;">or</span>
                    <div style="flex: 1; height: 1px; background: var(--line);"></div>
                </div>
                <a href="/auth/google" style="display: flex; align-items: center; justify-content: center; gap: 12px; width: 100%; border: 1.5px solid var(--line); border-radius: var(--radius); padding: 12px 16px; font-weight: 600; text-decoration: none; color: var(--text); background: var(--surface); transition: background-color 0.2s, border-color 0.2s; box-shadow: var(--shadow-sm); cursor: pointer;"
                   onmouseover="this.style.backgroundColor='var(--bg-warm)'; this.style.borderColor='var(--border)'"
                   onmouseout="this.style.backgroundColor='var(--surface)'; this.style.borderColor='var(--line)'">
                    <svg style="width: 20px; height: 20px;" viewBox="0 0 24 24">
                        <path fill="#EA4335" d="M5.266 9.765A7.077 7.077 0 0 1 12 4.909c1.69 0 3.218.6 4.418 1.582L19.91 3C17.782 1.145 15.055 0 12 0 7.336 0 3.327 2.673 1.327 6.573L5.266 9.765z"/>
                        <path fill="#4285F4" d="M23.491 12.273c0-.818-.073-1.609-.209-2.373H12v4.509h6.445c-.277 1.482-1.11 2.736-2.364 3.582l3.864 2.99A11.896 11.896 0 0 0 23.491 12.273z"/>
                        <path fill="#FBBC05" d="M5.266 14.235A7.127 7.127 0 0 1 4.909 12c0-.79.136-1.545.357-2.235L1.327 6.573A11.97 11.97 0 0 0 0 12c0 2.018.5 3.927 1.382 5.618l3.884-3.383z"/>
                        <path fill="#34A853" d="M12 24c3.245 0 5.973-1.073 7.964-2.91l-3.864-2.99C15.027 18.782 13.627 19.09 12 19.09c-3.155 0-5.818-2.127-6.773-4.99L1.345 17.482C3.355 21.355 7.355 24 12 24z"/>
                    </svg>
                    Continue with Google
                </a>
            </div>
        </div>
    </div>

    <!-- right side image -->
    <div class="auth-right">
        <div class="auth-right-content-wrapper">
            <div class="auth-right-logo">
                <span class="auth-logo-icon"><i class="fa-solid fa-heart-pulse"></i></span>
                <span class="auth-logo-text">Empathezee</span>
            </div>
            <h2 class="auth-right-title">You don't have to fight your illness alone.</h2>
            <p class="auth-right-subtitle">Connect with patients who understand, share experiences, consult verified doctors, and access curated health tracking tools.</p>
            <div class="auth-right-stats">
                <div class="auth-stat-item">
                    <span class="auth-stat-num">10k+</span>
                    <span class="auth-stat-lbl">Active Peers</span>
                </div>
                <div class="auth-stat-item">
                    <span class="auth-stat-num">250+</span>
                    <span class="auth-stat-lbl">Verified Doctors</span>
                </div>
                <div class="auth-stat-item">
                    <span class="auth-stat-num">50+</span>
                    <span class="auth-stat-lbl">Support Groups</span>
                </div>
            </div>
        </div>
    </div>

</div>

<script>
document.addEventListener('DOMContentLoaded', function() {
    var countryEl = document.getElementById('country');
    var stateEl = document.getElementById('state');
    var districtEl = document.getElementById('district');
    var cityEl = document.getElementById('city');

    var stateInput = document.getElementById('state-input');
    var districtInput = document.getElementById('district-input');
    var cityInput = document.getElementById('city-input');

    function configureField(prefix, mode) {
        var group = document.getElementById(prefix + '-group');
        var select = document.getElementById(prefix);
        var input = document.getElementById(prefix + '-input');

        if (mode === 'select') {
            group.style.display = 'flex';
            select.style.display = 'block';
            select.setAttribute('name', prefix);
            input.style.display = 'none';
            input.removeAttribute('name');
        } else if (mode === 'input') {
            group.style.display = 'flex';
            select.style.display = 'none';
            select.removeAttribute('name');
            input.style.display = 'block';
            input.setAttribute('name', prefix);
        } else {
            group.style.display = 'none';
            select.removeAttribute('name');
            input.removeAttribute('name');
        }
    }

    // populate countries
    var countries = LOCATION_DATA.getCountries();
    countries.forEach(function(c) {
        var opt = document.createElement('option');
        opt.value = c;
        opt.textContent = c;
        countryEl.appendChild(opt);
    });

    // country change → populate states (if india)
    countryEl.addEventListener('change', function() {
        var country = this.value;
        stateEl.innerHTML = '<option value="">Select State</option>';
        districtEl.innerHTML = '<option value="">Select District</option>';
        cityEl.innerHTML = '<option value="">Select City</option>';

        stateInput.value = '';
        districtInput.value = '';
        cityInput.value = '';

        if (!country) {
            configureField('state', 'none');
            configureField('district', 'none');
            configureField('city', 'none');
        } else if (LOCATION_DATA.hasDetailedData(country)) {
            var states = LOCATION_DATA.getStates(country);
            states.forEach(function(s) {
                var opt = document.createElement('option');
                opt.value = s;
                opt.textContent = s;
                stateEl.appendChild(opt);
            });
            configureField('state', 'select');
            configureField('district', 'none');
            configureField('city', 'none');
        } else {
            configureField('state', 'input');
            configureField('district', 'input');
            configureField('city', 'input');
        }
    });

    // state change → populate districts
    stateEl.addEventListener('change', function() {
        var state = this.value;
        districtEl.innerHTML = '<option value="">Select District</option>';
        cityEl.innerHTML = '<option value="">Select City</option>';
        districtInput.value = '';
        cityInput.value = '';

        if (state) {
            var districts = LOCATION_DATA.getDistricts(state);
            districts.forEach(function(d) {
                var opt = document.createElement('option');
                opt.value = d;
                opt.textContent = d;
                districtEl.appendChild(opt);
            });
            configureField('district', 'select');
            configureField('city', 'none');
        } else {
            configureField('district', 'none');
            configureField('city', 'none');
        }
    });

    // district change → populate cities
    districtEl.addEventListener('change', function() {
        var district = this.value;
        cityEl.innerHTML = '<option value="">Select City</option>';
        cityInput.value = '';

        if (district) {
            var cities = LOCATION_DATA.getCities(district);
            cities.forEach(function(c) {
                var opt = document.createElement('option');
                opt.value = c;
                opt.textContent = c;
                cityEl.appendChild(opt);
            });
            configureField('city', 'select');
        } else {
            configureField('city', 'none');
        }
    });
});
</script>

<%- include('../includes/footer') %>