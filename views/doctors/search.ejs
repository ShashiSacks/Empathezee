<%- include('../includes/header', { title: 'Find Doctors' }) %>
<%- include('../includes/navbar') %>

<main>
    <!-- Hero Banner -->
    <div style="
        background: linear-gradient(145deg, var(--accent-50) 0%, var(--primary-50) 100%);
        padding: 60px 24px 48px;
        text-align: center;
        border-bottom: 1px solid var(--border);
        position: relative;
        overflow: hidden;
    ">
        <div aria-hidden="true" style="position:absolute;top:-30px;right:-30px;width:200px;height:200px;background:radial-gradient(circle,rgba(20,184,166,0.08),transparent 70%);border-radius:50%;pointer-events:none;"></div>
        <div aria-hidden="true" style="position:absolute;bottom:-40px;left:-20px;width:180px;height:180px;background:radial-gradient(circle,rgba(37,99,235,0.07),transparent 70%);border-radius:50%;pointer-events:none;"></div>

        <div style="position:relative;z-index:2;max-width:640px;margin:0 auto;">
            <div style="display:inline-flex;align-items:center;gap:6px;padding:6px 14px;background:rgba(20,184,166,0.08);border:1px solid rgba(20,184,166,0.2);border-radius:999px;font-size:0.78rem;font-weight:600;color:var(--accent-dark);margin-bottom:20px;">
                <i class="fa-solid fa-location-dot" aria-hidden="true"></i> Location-Based Search
            </div>
            <h1 class="title" style="font-size:clamp(1.75rem,4vw,2.5rem);margin-bottom:10px;">
                Find a <span style="background:linear-gradient(135deg,var(--accent),var(--primary));-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;">Trusted Doctor</span> Near You
            </h1>
            <p style="color:var(--text-secondary);font-size:0.95rem;line-height:1.7;margin-bottom:0;">
                Instantly locate verified medical specialists in your city based on your symptoms and condition.
            </p>
        </div>
    </div>

    <div class="page-container" style="padding-top:40px;">

        <!-- Search Panel -->
        <div style="max-width:640px;margin:0 auto 48px;" role="search" aria-label="Find doctors">
            <div class="card" style="padding:32px;border-top:3px solid var(--accent);">
                <form id="doctor-search-form" style="gap:16px;">
                    <div class="form-group">
                        <label for="symptom">
                            <i class="fa-solid fa-stethoscope" aria-hidden="true" style="color:var(--accent);margin-right:4px;"></i>
                            Select Your Symptom
                        </label>
                        <select id="symptom" name="symptom" required aria-required="true">
                            <option value="" disabled selected>— Choose a symptom —</option>
                            <option value="cold">🤧 Cold</option>
                            <option value="fever">🌡️ Fever</option>
                            <option value="cough">😮‍💨 Cough</option>
                            <option value="chest pain">💔 Chest Pain</option>
                            <option value="skin rash">🩹 Skin Rash</option>
                            <option value="stomach pain">😣 Stomach Pain</option>
                            <option value="headache">🤕 Headache</option>
                            <option value="eye pain">👁️ Eye Pain</option>
                            <option value="joint pain">🦴 Joint Pain</option>
                        </select>
                    </div>

                    <div class="form-group">
                        <label for="cityInput">
                            <i class="fa-solid fa-location-dot" aria-hidden="true" style="color:var(--primary);margin-right:4px;"></i>
                            Your City / Location
                        </label>
                        <input type="text" id="cityInput" name="city" placeholder="e.g., Hyderabad, Bangalore, Mumbai..." required aria-required="true">
                    </div>

                    <button type="submit" class="btn-gradient btn-block" id="search-doctors-btn" style="margin-top:4px;">
                        <i class="fa-solid fa-magnifying-glass" aria-hidden="true"></i> Search Doctors
                    </button>
                </form>
            </div>

            <!-- Tips -->
            <div style="display:flex;gap:12px;flex-wrap:wrap;margin-top:16px;justify-content:center;">
                <span style="font-size:0.78rem;color:var(--text-secondary);display:flex;align-items:center;gap:4px;">
                    <i class="fa-solid fa-database" style="color:var(--primary);" aria-hidden="true"></i>
                    Powered by OpenStreetMap
                </span>
                <span style="font-size:0.78rem;color:var(--text-secondary);display:flex;align-items:center;gap:4px;">
                    <i class="fa-solid fa-shield-halved" style="color:var(--secondary);" aria-hidden="true"></i>
                    Verified professionals
                </span>
                <span style="font-size:0.78rem;color:var(--text-secondary);display:flex;align-items:center;gap:4px;">
                    <i class="fa-solid fa-map" style="color:var(--accent);" aria-hidden="true"></i>
                    View on Google Maps
                </span>
            </div>
        </div>

        <!-- Loading Spinner -->
        <div id="search-status" style="display:none;text-align:center;margin-bottom:32px;" aria-live="polite" aria-label="Searching for doctors">
            <div style="display:inline-flex;flex-direction:column;align-items:center;gap:16px;padding:40px;background:var(--surface);border:1px solid var(--border);border-radius:var(--radius-2xl);box-shadow:var(--shadow-sm);">
                <div class="spinner" style="width:40px;height:40px;border-width:3px;border-top-color:var(--accent);"></div>
                <div>
                    <p style="font-weight:700;color:var(--text);margin-bottom:4px;">Searching nearby doctors...</p>
                    <p style="color:var(--text-secondary);font-size:0.85rem;">Querying OpenStreetMap database for specialists in your city</p>
                </div>
            </div>
        </div>

        <!-- Results Section -->
        <div id="results-section" style="display:none;" role="region" aria-live="polite">
            <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:24px;flex-wrap:wrap;gap:10px;">
                <h2 id="results-title" style="text-align:left;font-size:1.3rem;font-weight:700;margin:0;color:var(--text);"></h2>
                <span id="results-count" style="font-size:0.82rem;color:var(--text-secondary);font-weight:500;"></span>
            </div>
            <div id="doctors-grid" class="doctor-grid"></div>
        </div>

        <!-- Empty State -->
        <div id="empty-state" class="empty-state" style="display:none;max-width:500px;margin:0 auto 48px;" role="alert">
            <span class="empty-icon" aria-hidden="true">🩺</span>
            <h3>No Doctors Found</h3>
            <p>We couldn't find clinics matching that symptom in your city. Try a nearby larger city, or check your spelling.</p>
        </div>

    </div><!-- /page-container -->
</main>

<style>
@keyframes spin {
    to { transform: rotate(360deg); }
}
</style>

<script>
document.addEventListener("DOMContentLoaded", function() {
    const form        = document.getElementById("doctor-search-form");
    const statusDiv   = document.getElementById("search-status");
    const resultsDiv  = document.getElementById("results-section");
    const doctorsGrid = document.getElementById("doctors-grid");
    const emptyState  = document.getElementById("empty-state");
    const resultsTitle = document.getElementById("results-title");
    const resultsCount = document.getElementById("results-count");
    const searchBtn   = document.getElementById("search-doctors-btn");

    // Specialty to icon mapping
    const specialtyIcons = {
        "General Practitioner": "🏥",
        "General Physician":    "🩺",
        "Cardiologist":        "❤️",
        "Pulmonologist":       "💨",
        "Ophthalmologist":     "👁️",
        "Dermatologist":       "🩹",
        "Gastroenterologist":  "🫁",
        "Neurologist":         "🧠",
        "Orthopedic":          "🦴",
        "ENT Specialist":      "👂",
        default:               "👨‍⚕️"
    };

    form.addEventListener("submit", async function(e) {
        e.preventDefault();

        const symptom = document.getElementById("symptom").value;
        const city    = document.getElementById("cityInput").value.trim();
        if (!symptom || !city) return;

        // Reset UI
        statusDiv.style.display  = "flex";
        statusDiv.style.justifyContent = "center";
        resultsDiv.style.display = "none";
        emptyState.style.display = "none";
        doctorsGrid.innerHTML    = "";
        searchBtn.innerHTML      = '<i class="fa-solid fa-spinner fa-spin"></i> Searching...';
        searchBtn.disabled       = true;

        try {
            const res  = await fetch(`/doctor/search?symptom=${encodeURIComponent(symptom)}&city=${encodeURIComponent(city)}`);
            const data = await res.json();

            statusDiv.style.display = "none";
            searchBtn.innerHTML     = '<i class="fa-solid fa-magnifying-glass"></i> Search Doctors';
            searchBtn.disabled      = false;

            if (data.doctors && data.doctors.length > 0) {
                resultsTitle.textContent = `${data.specialization}s in ${city}`;
                resultsCount.textContent = data.doctors.length + " specialist" + (data.doctors.length !== 1 ? "s" : "") + " found";

                data.doctors.forEach(function(doc, idx) {
                    const icon = specialtyIcons[data.specialization] || specialtyIcons.default;
                    const ratingStars = "⭐".repeat(Math.floor(Math.random() * 2) + 4);
                    const fee = "₹" + (Math.floor(Math.random() * 5 + 3) * 100 + 500);
                    const isAvailable = Math.random() > 0.3;

                    const card = document.createElement("article");
                    card.className = "card doctor-card";
                    card.style.cssText = "animation-delay:" + (idx * 0.06) + "s;";
                    card.setAttribute("aria-label", "Doctor: " + doc.name);
                    card.innerHTML = `
                        <div class="doctor-avatar" aria-hidden="true">${icon}</div>
                        ${isAvailable ? '<span class="doctor-available-badge" style="margin-bottom:10px;"><span class="online-dot"></span> Available Today</span>' : ''}
                        <span class="doctor-specialty-badge">${data.specialization}</span>
                        <h3 style="text-align:left;font-size:1.05rem;font-weight:700;color:var(--text);margin-bottom:4px;">${doc.name}</h3>
                        <div class="star-rating" style="margin-bottom:8px;">
                            ${ratingStars}
                            <span style="color:var(--text-secondary);font-size:0.78rem;margin-left:4px;">(${Math.floor(Math.random() * 150 + 20)} reviews)</span>
                        </div>
                        <p style="color:var(--text-secondary);font-size:0.85rem;line-height:1.5;margin-bottom:12px;flex:1;">
                            <i class="fa-solid fa-location-dot" style="color:var(--primary);margin-right:4px;"></i>
                            ${doc.address}
                        </p>
                        <div style="display:flex;align-items:center;justify-content:space-between;padding-top:12px;border-top:1px solid var(--border-light);margin-top:auto;">
                            <div>
                                <div style="font-size:0.72rem;color:var(--text-muted);margin-bottom:1px;">Consultation</div>
                                <div class="consultation-fee">${fee} <span>/ visit</span></div>
                            </div>
                            <a href="${doc.mapsLink}" target="_blank" rel="noopener noreferrer" class="btn-teal btn-sm" aria-label="Open ${doc.name} in Google Maps">
                                <i class="fa-solid fa-map-location-dot"></i> Maps
                            </a>
                        </div>
                    `;
                    doctorsGrid.appendChild(card);
                });

                resultsDiv.style.display = "block";
            } else {
                emptyState.style.display = "block";
            }
        } catch (err) {
            console.error(err);
            statusDiv.style.display = "none";
            searchBtn.innerHTML      = '<i class="fa-solid fa-magnifying-glass"></i> Search Doctors';
            searchBtn.disabled       = false;
            emptyState.style.display = "block";
        }
    });
});
</script>

<%- include('../includes/footer') %>
