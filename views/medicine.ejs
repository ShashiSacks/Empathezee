<%- include('partials/header', { title: 'Medicines Directory' }) %>
<%- include('partials/navbar') %>
<script src="https://js.stripe.com/v3/"></script>

<style>
@keyframes spin {
    0% { transform: rotate(0deg); }
    100% { transform: rotate(360deg); }
}
</style>

<main class="page-container" style="max-width: 800px; margin: 0 auto; padding: 40px 20px;">
    <div style="text-align: center; margin-bottom: 36px; margin-top: 20px;">
        <h1 class="title" style="font-size: 2.2rem; margin-bottom: 8px; font-family: 'Outfit', sans-serif; font-weight: 800; letter-spacing: -1px; color: var(--primary);">💊 Medicine Search</h1>
        <p style="color: var(--text-secondary); font-size: 1rem; max-width: 550px; margin: 0 auto; line-height: 1.6;">Search verified medical databases (Mayo Clinic, WebMD, NIH, Wikipedia) for instant drug guides, dosages, and book orders.</p>
    </div>

    <!-- GOOGLE PROGRAMMABLE SEARCH ENGINE (INTERACTIVE HERO PANEL) -->
    <div class="google-cse-section card" style="margin-bottom: 40px; padding: 32px; box-shadow: var(--shadow-md); border-radius: var(--radius-lg); background: var(--surface); border: 1.5px solid var(--line); text-align: left;">
        <form id="google-search-form" class="search-form" style="display: flex; gap: 12px; margin-bottom: 0;">
            <select id="searchType" style="max-width: 220px; font-size: 0.9rem; background: var(--bg-warm); border: 1px solid var(--line); font-weight: 600; border-radius: var(--radius-sm); padding: 8px 12px; color: var(--text);">
                <option value="medicine" selected>Search Drug / Medicine Info</option>
                <option value="disease">Search Disease Info</option>
            </select>
            <input type="text" id="googleQuery" placeholder="Enter query (e.g. cold, fever, asthma, ibuprofen)..." required style="flex: 1; font-size: 0.95rem; padding: 12px 16px; border-radius: var(--radius-sm); border: 1.5px solid var(--line); background: var(--bg-warm); outline: none; transition: border-color 0.2s; color: var(--text);" value="<%= typeof searchQuery !== 'undefined' ? searchQuery : '' %>" />
            <button type="submit" class="btn-primary" style="padding: 12px 28px; font-weight: 600; font-size: 0.95rem; border-radius: var(--radius-sm); border: none; cursor: pointer;">Search</button>
        </form>

        <!-- Loading state -->
        <div id="google-search-status" style="display: none; text-align: center; margin-top: 32px; width: 100%;">
            <div class="spinner" style="margin: 15px auto; border: 4px solid var(--border); border-top: 4px solid var(--accent); border-radius: 50%; width: 36px; height: 36px; animation: spin 1s linear infinite;"></div>
            <p style="color: var(--text-secondary); font-size: 0.9rem; font-weight: 500;">Querying Google medical index...</p>
        </div>
    </div>

    <!-- MIDDLE: SEARCH RESULTS SECTION -->
    <div id="google-results" style="display: none; margin-bottom: 40px;">
        <h3 style="text-align: left; margin-bottom: 20px; color: var(--primary); font-size: 1.3rem; font-weight: 700; letter-spacing: -0.5px; border-bottom: 2px solid var(--line); padding-bottom: 8px;">Top Medical Results</h3>
        <div id="google-results-list" style="display: flex; flex-direction: column; gap: 20px;">
            <!-- Result items loaded dynamically -->
        </div>
    </div>

    <!-- Empty state -->
    <div id="google-empty" style="display: none; margin-bottom: 40px; text-align: center; padding: 40px 20px; border: 2px dashed var(--line); border-radius: var(--radius-lg); background: var(--surface);">
        <span style="font-size: 2.5rem; display: block; margin-bottom: 12px;">🔍</span>
        <h3 style="color: var(--text); font-size: 1.15rem; margin-bottom: 6px; font-weight: 700;">No Results Found</h3>
        <p style="color: var(--text-secondary); margin: 0; font-size: 0.9rem;">We couldn't find any trusted medical resources for that term. Try another query.</p>
    </div>
</main>

<script>
document.addEventListener("DOMContentLoaded", function() {
    const form = document.getElementById("google-search-form");
    const searchType = document.getElementById("searchType");
    const queryInput = document.getElementById("googleQuery");
    const statusDiv = document.getElementById("google-search-status");
    const resultsDiv = document.getElementById("google-results");
    const resultsList = document.getElementById("google-results-list");
    const emptyDiv = document.getElementById("google-empty");

    async function performSearch(query, type) {
        if (!query) return;

        // Reset UI state
        statusDiv.style.display = "block";
        resultsDiv.style.display = "none";
        emptyDiv.style.display = "none";
        resultsList.innerHTML = "";

        const endpoint = type === "disease" ? "/search-disease" : "/medicine-info";

        try {
            const res = await fetch(`${endpoint}?query=${encodeURIComponent(query)}`);
            const data = await res.json();

            statusDiv.style.display = "none";

            if (data.results && data.results.length > 0) {
                const topResults = data.results.slice(0, 5);
                topResults.forEach(item => {
                    const card = document.createElement("div");
                    card.className = "search-result-item-card";
                    card.style.padding = "24px";
                    card.style.border = "1.5px solid var(--line)";
                    card.style.borderRadius = "var(--radius-lg)";
                    card.style.background = "var(--surface)";
                    card.style.display = "flex";
                    card.style.flexDirection = "column";
                    card.style.gap = "12px";
                    card.style.boxShadow = "var(--shadow-sm)";
                    card.style.transition = "transform 0.2s var(--ease), box-shadow 0.2s var(--ease), border-color 0.2s var(--ease)";
                    card.style.textAlign = "left";

                    // Hover effects
                    card.addEventListener("mouseover", function() {
                        card.style.transform = "translateY(-3px)";
                        card.style.boxShadow = "var(--shadow-md)";
                        card.style.borderColor = "var(--accent)";
                    });
                    card.addEventListener("mouseout", function() {
                        card.style.transform = "none";
                        card.style.boxShadow = "var(--shadow-sm)";
                        card.style.borderColor = "var(--line)";
                    });

                    let sourceName = "Verified Source";
                    if (item.link.includes("mayoclinic.org")) sourceName = "Mayo Clinic";
                    else if (item.link.includes("webmd.com")) sourceName = "WebMD";
                    else if (item.link.includes("nih.gov")) sourceName = "NIH";
                    else if (item.link.includes("wikipedia.org")) sourceName = "Wikipedia";

                    const cleanName = item.title.split('-')[0].split('|')[0].split(':')[0].trim();

                    card.innerHTML = `
                        <div style="display: flex; justify-content: space-between; align-items: flex-start; gap: 16px;">
                            <h4 style="margin: 0; font-size: 1.15rem; font-family: 'Outfit', sans-serif; text-align: left; line-height: 1.4;">
                                <a href="${item.link}" target="_blank" style="color: var(--primary); text-decoration: none; font-weight: 700; transition: color 0.15s;">${item.title}</a>
                            </h4>
                            <span style="background: var(--bg-warm); color: var(--text-secondary); font-size: 0.75rem; font-weight: 600; padding: 4px 10px; border-radius: var(--radius-sm); border: 1px solid var(--border); white-space: nowrap;">${sourceName}</span>
                        </div>
                        <p style="margin: 0; color: var(--text-secondary); font-size: 0.9rem; line-height: 1.6; text-align: left;">
                            <b>Usage:</b> ${item.snippet}
                        </p>
                        <div style="margin-top: 8px; display: flex; justify-content: space-between; align-items: center; border-top: 1px solid var(--line-light); padding-top: 16px;">
                            <a href="${item.link}" target="_blank" style="color: var(--accent); font-size: 0.85rem; font-weight: 600; text-decoration: none; display: flex; align-items: center; gap: 4px;">
                                🔗 View source on ${sourceName}
                            </a>
                            <button onclick="openCheckoutModal('${cleanName.replace(/'/g, "\\'")}')" class="btn-success" style="padding: 8px 18px; font-size: 0.85rem; font-weight: 600; border-radius: var(--radius-sm); display: flex; align-items: center; gap: 6px; box-shadow: var(--shadow-xs); border: none; cursor: pointer;">
                                🛒 Book & Pay
                            </button>
                        </div>
                    `;
                    resultsList.appendChild(card);
                });
                resultsDiv.style.display = "block";
            } else {
                emptyDiv.style.display = "block";
            }
        } catch (err) {
            console.error(err);
            statusDiv.style.display = "none";
            alert("Error querying Google search. Please try again later.");
        }
    }

    form.addEventListener("submit", function(e) {
        e.preventDefault();
        performSearch(queryInput.value.trim(), searchType.value);
    });

    // Auto-trigger search if query parameter exists
    const initialQuery = "<%= typeof searchQuery !== 'undefined' ? searchQuery : '' %>";
    if (initialQuery.trim()) {
        performSearch(initialQuery.trim(), "medicine");
    }
});


// Checkout Modal Actions
const userCity = "<%= user?.city || '' %>";
const modal = document.getElementById("checkout-modal");
const modalMedName = document.getElementById("modal-med-name");
const modalMedQty = document.getElementById("modal-med-qty");
const modalDeliveryAddr = document.getElementById("modal-delivery-addr");
const modalTotalAmt = document.getElementById("modal-total-amt");
const checkoutForm = document.getElementById("checkout-form");
const paymentProcessing = document.getElementById("payment-processing");
const paymentSuccess = document.getElementById("payment-success");

// Initialize Stripe Elements
const stripeKey = "<%= stripePublishableKey %>";
let stripe = null;
let elements = null;
let cardElement = null;

if (stripeKey) {
    stripe = Stripe(stripeKey);
    elements = stripe.elements();
    
    const style = {
        base: {
            color: "#1c1917",
            fontFamily: "Inter, system-ui, sans-serif",
            fontSmoothing: "antialiased",
            fontSize: "14px",
            "::placeholder": {
                color: "#a8a29e"
            }
        },
        invalid: {
            color: "#dc2626",
            iconColor: "#dc2626"
        }
    };
    
    cardElement = elements.create("card", { style });
    cardElement.mount("#card-element");
    
    cardElement.on("change", function(event) {
        const displayError = document.getElementById("card-errors");
        if (event.error) {
            displayError.textContent = event.error.message;
            displayError.style.display = "block";
        } else {
            displayError.textContent = "";
            displayError.style.display = "none";
        }
    });
}

function openCheckoutModal(medicineName) {
    modalMedName.value = medicineName;
    modalMedQty.value = "1";
    modalDeliveryAddr.value = userCity ? userCity + ", India" : "";
    modalTotalAmt.textContent = "₹150.00";
    
    // Reset views
    checkoutForm.style.display = "flex";
    paymentProcessing.style.display = "none";
    paymentSuccess.style.display = "none";
    
    // Clear card inputs if stripe is loaded
    if (cardElement) {
        cardElement.clear();
        document.getElementById("card-errors").style.display = "none";
    }
    
    modal.style.display = "flex";
}

function closeCheckoutModal() {
    modal.style.display = "none";
}

document.getElementById("close-modal-btn").addEventListener("click", closeCheckoutModal);
document.getElementById("success-close-btn").addEventListener("click", closeCheckoutModal);

// Toggle dynamic payment inputs
document.querySelectorAll('input[name="paymentOption"]').forEach(radio => {
    radio.addEventListener("change", function() {
        const upiGroup = document.getElementById("payment-upi-group");
        const cardGroup = document.getElementById("payment-card-group");
        
        if (this.value === "upi") {
            upiGroup.style.display = "flex";
            cardGroup.style.display = "none";
        } else if (this.value === "card") {
            upiGroup.style.display = "none";
            cardGroup.style.display = "flex";
        } else {
            upiGroup.style.display = "none";
            cardGroup.style.display = "none";
        }
    });
});

// Update dynamic price
modalMedQty.addEventListener("change", function() {
    const qty = parseInt(this.value, 10);
    modalTotalAmt.textContent = "₹" + (qty * 150) + ".00";
});

// Submit payment order
checkoutForm.addEventListener("submit", async function(e) {
    e.preventDefault();
    
    const medicineName = modalMedName.value.trim();
    const quantity = modalMedQty.value;
    const address = modalDeliveryAddr.value.trim();
    const paymentMethod = document.querySelector('input[name="paymentOption"]:checked').value;
    
    // Hide form, show processing spinner
    checkoutForm.style.display = "none";
    paymentProcessing.style.display = "block";
    
    try {
        const response = await fetch("/api/medicine/order", {
            method: "POST",
            headers: {
                "Content-Type": "application/json"
            },
            body: JSON.stringify({
                medicineName,
                quantity,
                address,
                paymentMethod
            })
        });
        
        const data = await response.json();
        
        if (!response.ok) {
            alert(data.message || "Checkout failed. Please try again.");
            checkoutForm.style.display = "flex";
            paymentProcessing.style.display = "none";
            return;
        }

        if (data.requiresAction && paymentMethod === "card") {
            // Stripe payment validation
            const { error, paymentIntent } = await stripe.confirmCardPayment(data.clientSecret, {
                payment_method: {
                    card: cardElement,
                    billing_details: {
                        name: "<%= user?.username %>",
                        email: "<%= user?.email %>"
                    }
                }
            });

            if (error) {
                // Show card confirmation errors
                const errorDiv = document.getElementById("card-errors");
                errorDiv.textContent = error.message;
                errorDiv.style.display = "block";
                
                checkoutForm.style.display = "flex";
                paymentProcessing.style.display = "none";
            } else if (paymentIntent.status === "succeeded") {
                // Confirm paid order status in database
                const confirmRes = await fetch("/api/medicine/confirm-payment", {
                    method: "POST",
                    headers: {
                        "Content-Type": "application/json"
                    },
                    body: JSON.stringify({
                        orderId: data.orderId,
                        paymentIntentId: paymentIntent.id
                    })
                });

                if (confirmRes.ok) {
                    document.getElementById("success-order-id").textContent = data.orderId;
                    document.getElementById("success-med-name").textContent = medicineName;
                    document.getElementById("success-med-qty").textContent = quantity + " Pack(s)";
                    document.getElementById("success-med-addr").textContent = address;
                    paymentSuccess.style.display = "block";
                } else {
                    alert("Order booked, but payment confirmation failed in database.");
                    checkoutForm.style.display = "flex";
                }
                paymentProcessing.style.display = "none";
            }
        } else {
            // For UPI or COD
            document.getElementById("success-order-id").textContent = data.orderId;
            document.getElementById("success-med-name").textContent = medicineName;
            document.getElementById("success-med-qty").textContent = quantity + " Pack(s)";
            document.getElementById("success-med-addr").textContent = address;
            paymentSuccess.style.display = "block";
            paymentProcessing.style.display = "none";
        }
        
    } catch (err) {
        console.error(err);
        paymentProcessing.style.display = "none";
        checkoutForm.style.display = "flex";
        alert("An error occurred during payment processing. Please try again.");
    }
});
</script>

<!-- CHECKOUT & BOOKING MODAL -->
<div id="checkout-modal" style="display: none; position: fixed; inset: 0; background: rgba(0, 0, 0, 0.5); z-index: 10000; justify-content: center; align-items: center; padding: 20px; backdrop-filter: blur(4px);">
    <div class="card" style="width: 100%; max-width: 500px; background: var(--surface); border-radius: var(--radius-lg); box-shadow: var(--shadow-xl); padding: 30px; text-align: left; position: relative;">
        <button id="close-modal-btn" style="position: absolute; top: 15px; right: 15px; border: none; background: transparent; font-size: 1.5rem; cursor: pointer; color: var(--text-secondary);">&times;</button>
        
        <h2 style="margin-top: 0; color: var(--primary); font-size: 1.4rem; text-align: left; margin-bottom: 20px; letter-spacing: -0.5px;">💳 Book & Pay for Medicine</h2>
        
        <!-- Step 1: Form -->
        <form id="checkout-form" style="display: flex; flex-direction: column; gap: 16px;">
            <div class="form-group">
                <label for="modal-med-name" style="text-align: left;">Medicine Name</label>
                <input type="text" id="modal-med-name" required placeholder="Enter medicine name" style="font-size: 0.9rem;" />
            </div>

            <div class="form-group">
                <label for="modal-med-qty" style="text-align: left;">Select Quantity</label>
                <select id="modal-med-qty" style="font-size: 0.9rem;">
                    <option value="1">1 Pack / Bottle</option>
                    <option value="2">2 Packs / Bottles</option>
                    <option value="3">3 Packs / Bottles</option>
                    <option value="5">5 Packs / Bottles</option>
                    <option value="10">10 Packs / Bottles</option>
                </select>
            </div>

            <div class="form-group">
                <label for="modal-delivery-addr" style="text-align: left;">Delivery Address</label>
                <textarea id="modal-delivery-addr" required placeholder="Enter full delivery address..." style="font-size: 0.9rem; min-height: 60px;"></textarea>
            </div>

            <div class="form-group">
                <label style="text-align: left;">Payment Option</label>
                <div style="display: flex; flex-direction: column; gap: 8px; margin-top: 4px;">
                    <label style="display: flex; align-items: center; gap: 8px; cursor: pointer; font-size: 0.9rem; text-transform: none; font-weight: 500; color: var(--text);">
                        <input type="radio" name="paymentOption" value="upi" checked style="width: auto; height: auto; -webkit-appearance: radio; appearance: radio;" /> UPI Payment (GPay, PhonePe, Paytm)
                    </label>
                    <label style="display: flex; align-items: center; gap: 8px; cursor: pointer; font-size: 0.9rem; text-transform: none; font-weight: 500; color: var(--text);">
                        <input type="radio" name="paymentOption" value="card" style="width: auto; height: auto; -webkit-appearance: radio; appearance: radio;" /> Credit / Debit Card
                    </label>
                    <label style="display: flex; align-items: center; gap: 8px; cursor: pointer; font-size: 0.9rem; text-transform: none; font-weight: 500; color: var(--text);">
                        <input type="radio" name="paymentOption" value="cod" style="width: auto; height: auto; -webkit-appearance: radio; appearance: radio;" /> Cash on Delivery (COD)
                    </label>
                </div>
            </div>

            <!-- Dynamic Payment Fields -->
            <div id="payment-upi-group" class="form-group">
                <label for="modal-upi-id" style="text-align: left;">UPI ID</label>
                <input type="text" id="modal-upi-id" placeholder="e.g. user@okhdfcbank" style="font-size: 0.9rem;" />
            </div>

            <div id="payment-card-group" class="form-group" style="display: none;">
                <label style="text-align: left;">Stripe Secure Card Payment</label>
                <div id="card-element" style="padding: 12px; border: 1.5px solid var(--line); border-radius: var(--radius-sm); background: var(--surface);"></div>
                <div id="card-errors" role="alert" style="color: var(--danger); font-size: 0.8rem; margin-top: 4px; display: none;"></div>
            </div>

            <!-- Price Breakdown -->
            <div style="background: var(--bg-warm); padding: 14px; border-radius: var(--radius); border: 1px solid var(--line); font-size: 0.88rem; display: flex; flex-direction: column; gap: 6px; margin-top: 6px;">
                <div style="display: flex; justify-content: space-between;">
                    <span>Unit Price:</span>
                    <span style="font-weight: 600;">₹150.00</span>
                </div>
                <div style="display: flex; justify-content: space-between;">
                    <span>Delivery Charge:</span>
                    <span style="font-weight: 600; color: var(--success);">FREE</span>
                </div>
                <div style="border-top: 1px solid var(--line); margin: 4px 0; padding-top: 4px; display: flex; justify-content: space-between; font-size: 0.95rem; font-weight: 700; color: var(--primary);">
                    <span>Total Amount:</span>
                    <span id="modal-total-amt">₹150.00</span>
                </div>
            </div>

            <button type="submit" class="btn-primary-block" style="margin-top: 10px;">💳 Pay & Confirm Booking</button>
        </form>

        <!-- Step 2: Processing Spinner -->
        <div id="payment-processing" style="display: none; text-align: center; padding: 40px 0;">
            <div class="spinner" style="margin: 0 auto 20px; border: 4px solid var(--border); border-top: 4px solid var(--accent); border-radius: 50%; width: 48px; height: 48px; animation: spin 1s linear infinite;"></div>
            <h3 style="margin-bottom: 8px;">Processing Payment...</h3>
            <p style="color: var(--text-secondary); font-size: 0.9rem;">Please do not close or refresh this page.</p>
        </div>

        <!-- Step 3: Success Invoice -->
        <div id="payment-success" style="display: none; text-align: center; padding: 20px 0;">
            <span style="font-size: 4rem; display: block; margin-bottom: 12px;">✅</span>
            <h3 style="color: var(--success); font-size: 1.35rem; margin-bottom: 8px;">Booking Confirmed!</h3>
            <p style="color: var(--text-secondary); font-size: 0.9rem; margin-bottom: 24px;">Your payment was successful. The medicine has been ordered and will be delivered shortly.</p>
            
            <div style="background: var(--bg-warm); border: 1px solid var(--line); border-radius: var(--radius); padding: 18px; text-align: left; font-size: 0.88rem; display: flex; flex-direction: column; gap: 8px;">
                <div><b>Order ID:</b> <span id="success-order-id" style="font-family: monospace; font-weight: 600; color: var(--primary);"></span></div>
                <div><b>Medicine:</b> <span id="success-med-name" style="font-weight: 600;"></span></div>
                <div><b>Quantity:</b> <span id="success-med-qty"></span></div>
                <div><b>Delivery to:</b> <span id="success-med-addr"></span></div>
                <div><b>Status:</b> <span class="badge status-confirmed">Processing</span></div>
            </div>
            
            <button id="success-close-btn" class="btn-primary" style="margin-top: 24px; padding: 10px 24px;">Close Checkout</button>
        </div>
    </div>
</div>

<%- include('partials/footer') %>
