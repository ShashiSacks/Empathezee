<%- include('partials/header', { title: 'Disease Communities' }) %>
<%- include('partials/navbar') %>

<main class="page-container">
    <h1 class="title">Disease Communities</h1>

    <div class="medicine-layout">
        <!-- LEFT COLUMN: COMMUNITIES CATALOG -->
        <div class="medicine-list-section">
            <h2>👥 Support Groups</h2>
            
            <% if (!communities || communities.length === 0) { %>
                <div class="empty-state">
                    <span class="empty-icon">👥</span>
                    <h3>No Communities Found</h3>
                    <p>There are no medical support communities created yet. Create one on the right to start peer discussions!</p>
                </div>
            <% } else { %>
                <div class="appointment-grid" style="margin-top: 15px;">
                    <% communities.forEach((c) => { %>
                        <% 
                           const isRecommended = userDisease && c.disease.toLowerCase().includes(userDisease.toLowerCase());
                        %>
                        <div class="card community-card <%= isRecommended ? 'highlight-card' : '' %>" style="text-align: left; align-items: stretch;">
                            <% if (isRecommended) { %>
                                <span class="badge recommendation-badge" style="margin-bottom: 12px; align-self: flex-start;">✨ Matches Your Profile (<%= userDisease %>)</span>
                            <% } %>
                            <h3 style="text-align: left; font-size: 1.25rem;"><%= c.name %></h3>
                            <p class="community-desc" style="color: var(--text-muted); font-size: 0.95rem; line-height: 1.5; margin-bottom: 12px;"><%= c.description %></p>
                            <p class="community-disease" style="font-size: 0.9rem; margin-bottom: 12px;"><b>Target Disease:</b> <span style="background: rgba(79, 70, 229, 0.05); padding: 2px 6px; border-radius: 4px; font-weight: 600;"><%= c.disease %></span></p>

                            <!-- Meetup specifications (Online / In-person) -->
                            <div class="community-event-details" style="margin-bottom: 20px; padding: 12px; background: rgba(79, 70, 229, 0.03); border-radius: var(--radius); border: 1px solid rgba(79, 70, 229, 0.06); font-size: 0.88rem; display: flex; flex-direction: column; gap: 6px;">
                                <p style="margin: 0;">
                                    <b>Type:</b> 
                                    <span class="badge" style="background: <%= c.type === 'online' ? 'rgba(13, 148, 136, 0.1)' : 'rgba(217, 119, 6, 0.1)' %>; color: <%= c.type === 'online' ? 'var(--success)' : 'var(--warning)' %>; padding: 2px 6px; border-radius: 4px; font-weight: 700; text-transform: uppercase; font-size: 0.75rem;">
                                        <%= c.type || 'online' %>
                                    </span>
                                </p>
                                <% if (c.type === 'offline') { %>
                                    <p style="margin: 0;"><b>Date:</b> <%= c.meetingDate %></p>
                                    <p style="margin: 0;"><b>Time:</b> <%= c.meetingTime %></p>
                                    <p style="margin: 0;"><b>Location:</b> 📍 <%= c.meetingPlace %></p>
                                <% } %>
                                <p style="margin: 0;">
                                    <b>Access Fee:</b> 
                                    <span style="font-weight: 700; color: <%= c.paymentType === 'paid' ? 'var(--danger)' : 'var(--success)' %>">
                                        <%= c.paymentType === 'paid' ? `Paid (₹${c.price})` : 'Free 🟢' %>
                                    </span>
                                </p>
                            </div>

                            <div class="community-actions">
                                <% if (userCommunities.includes(c._id.toString())) { %>
                                    <div style="display: flex; gap: 10px; width: 100%;">
                                        <form action="/api/communities/<%= c._id %>/leave" method="POST" style="flex: 1; margin: 0; background: transparent; border: none; box-shadow: none; padding: 0;">
                                            <button type="submit" class="btn-danger-outline" style="width: 100%; padding: 8px 12px; font-size: 0.85rem; font-weight: 600; min-width: unset;">Leave Group</button>
                                        </form>
                                        <a href="/community/<%= c._id %>" class="btn-primary" style="flex: 1; padding: 8px 12px; font-size: 0.85rem; margin: 0; font-weight: 600; text-align: center; text-decoration: none;">Enter Group</a>
                                    </div>
                                <% } else { %>
                                    <form action="/api/communities/<%= c._id %>/join" method="POST" style="width: 100%; margin: 0; background: transparent; border: none; box-shadow: none; padding: 0;">
                                        <button type="submit" class="btn-success" style="width: 100%; padding: 8px 12px; font-size: 0.85rem; font-weight: 600; min-width: unset;">Join Community</button>
                                    </form>
                                <% } %>
                            </div>
                        </div>
                    <% }) %>
                </div>
            <% } %>
        </div>

        <!-- RIGHT COLUMN: CREATE COMMUNITY -->
        <div class="medicine-form-section">
            <h2>➕ Create Community</h2>
            <form action="/api/communities" method="POST" class="form-card" style="margin-top: 15px;">
                <div class="form-group">
                    <label for="name">Community Name</label>
                    <input type="text" name="name" id="name" required placeholder="e.g. Aids support group">
                </div>

                <div class="form-group">
                    <label for="disease">Target Disease</label>
                    <input type="text" name="disease" id="disease" required placeholder="e.g. Aids">
                </div>

                <div class="form-group">
                    <label for="type">Format / Type</label>
                    <select name="type" id="type" required onchange="toggleEventDetails(this.value)">
                        <option value="online" selected>Online Discussion</option>
                        <option value="offline">Offline (In-Person Meeting)</option>
                    </select>
                </div>

                <!-- Offline Schedule Details (Toggled via JS) -->
                <div id="offline-details" style="display: none; border-left: 2px solid var(--warning); padding-left: 12px; margin-bottom: 20px;">
                    <div class="form-group">
                        <label for="meetingDate">Meeting Date</label>
                        <input type="date" name="meetingDate" id="meetingDate">
                    </div>

                    <div class="form-group">
                        <label for="meetingTime">Meeting Time</label>
                        <input type="time" name="meetingTime" id="meetingTime">
                    </div>

                    <div class="form-group">
                        <label for="meetingPlace">Meeting Address / Venue</label>
                        <input type="text" name="meetingPlace" id="meetingPlace" placeholder="e.g. Kadapa Hospital Hall">
                    </div>
                </div>

                <div class="form-group">
                    <label for="paymentType">Payment Access</label>
                    <select name="paymentType" id="paymentType" required onchange="togglePrice(this.value)">
                        <option value="free" selected>Free</option>
                        <option value="paid">Paid Entry</option>
                    </select>
                </div>

                <!-- Paid Entry pricing (Toggled via JS) -->
                <div id="price-details" style="display: none; border-left: 2px solid var(--danger); padding-left: 12px; margin-bottom: 20px;">
                    <div class="form-group">
                        <label for="price">Entry Price (₹)</label>
                        <input type="number" name="price" id="price" min="0" step="1" placeholder="e.g. 150">
                    </div>
                </div>

                <div class="form-group">
                    <label for="description">Guidelines / Description</label>
                    <textarea name="description" id="description" required placeholder="Outline topics, meeting rules, or patient support goals..."></textarea>
                </div>

                <button type="submit" class="btn-primary-block">Create Community</button>
            </form>
        </div>
    </div>
</main>

<script>
    function toggleEventDetails(type) {
        const offlineDetails = document.getElementById('offline-details');
        const meetingDate = document.getElementById('meetingDate');
        const meetingTime = document.getElementById('meetingTime');
        const meetingPlace = document.getElementById('meetingPlace');
        if (type === 'offline') {
            offlineDetails.style.display = 'block';
            meetingDate.required = true;
            meetingTime.required = true;
            meetingPlace.required = true;
        } else {
            offlineDetails.style.display = 'none';
            meetingDate.required = false;
            meetingTime.required = false;
            meetingPlace.required = false;
        }
    }

    function togglePrice(paymentType) {
        const priceDetails = document.getElementById('price-details');
        const price = document.getElementById('price');
        if (paymentType === 'paid') {
            priceDetails.style.display = 'block';
            price.required = true;
        } else {
            priceDetails.style.display = 'none';
            price.required = false;
        }
    }
</script>

<%- include('partials/footer') %>