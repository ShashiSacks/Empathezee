<%- include('partials/header', { title: 'Your Profile' }) %>
<%- include('partials/navbar') %>

<main class="page-container">
    <h1 class="title">User Profile</h1>

    <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(320px, 1fr)); gap: 30px; margin-bottom: 40px;">
        <!-- left column: current profile details -->
        <div class="card" style="margin: 0; display: flex; flex-direction: column; justify-content: center; text-align: left;">
            <h2 style="text-align: center;">👤 <%= user.username %></h2>
            <div class="profile-details" style="display: flex; flex-direction: column; gap: 15px; margin-top: 25px;">
                <p style="text-align: left;"><b>Email:</b> <%= user.email %></p>
                <p style="text-align: left;"><b>Age:</b> <%= user.age || "Not set" %></p>
                <p style="text-align: left; text-transform: capitalize;"><b>Gender:</b> <%= user.gender || "Not set" %></p>
                <p style="text-align: left;"><b>Location:</b>
                    <%
                        var locationParts = [];
                        if (user.city) locationParts.push(user.city);
                        if (user.district) locationParts.push(user.district);
                        if (user.state) locationParts.push(user.state);
                        if (user.country) locationParts.push(user.country);
                    %>
                    <%= locationParts.length > 0 ? locationParts.join(', ') : 'Not set' %>
                </p>
                <p style="text-align: left;"><b>Target Disease:</b> <%= user.disease || "Not set" %></p>
            </div>
        </div>

        <!-- right column: edit profile details form -->
        <div class="card" style="margin: 0; text-align: left;">
            <h2 style="text-align: center;">✏️ Edit Details</h2>
            <form action="/api/users/profile" method="POST" style="margin-top: 20px; display: flex; flex-direction: column; background: transparent; border: none; box-shadow: none; padding: 0;">
                <div class="form-group">
                    <label for="username" style="font-weight: 600;">Username</label>
                    <input type="text" name="username" id="username" value="<%= user.username %>" required>
                </div>
                
                <div class="form-group">
                    <label for="email" style="font-weight: 600;">Email Address</label>
                    <input type="email" name="email" id="email" value="<%= user.email %>" required>
                </div>

                <div class="form-group">
                    <label for="age" style="font-weight: 600;">Age</label>
                    <input type="number" name="age" id="age" value="<%= user.age %>" placeholder="e.g., 21">
                </div>

                <div class="form-group">
                    <label for="gender" style="font-weight: 600;">Gender</label>
                    <select name="gender" id="gender">
                        <option value="male" <%= user.gender === 'male' ? 'selected' : '' %>>Male</option>
                        <option value="female" <%= user.gender === 'female' ? 'selected' : '' %>>Female</option>
                        <option value="other" <%= user.gender === 'other' ? 'selected' : '' %>>Other</option>
                    </select>
                </div>

                <div class="form-group">
                    <label for="disease" style="font-weight: 600;">Target Disease / Indication</label>
                    <input type="text" name="disease" id="disease" value="<%= user.disease %>" placeholder="e.g., Asthma">
                </div>

                <!-- location picker in profile edit -->
                <div class="location-picker">
                    <div class="form-group">
                        <label for="profile-country" style="font-weight: 600;">Country</label>
                        <select name="country" id="profile-country">
                            <option value="">Select Country</option>
                        </select>
                    </div>

                    <div class="form-group" id="profile-state-group" style="display: none;">
                        <label for="profile-state" style="font-weight: 600;">State</label>
                        <select name="state" id="profile-state">
                            <option value="">Select State</option>
                        </select>
                    </div>

                    <div class="form-group" id="profile-district-group" style="display: none;">
                        <label for="profile-district" style="font-weight: 600;">District</label>
                        <select name="district" id="profile-district">
                            <option value="">Select District</option>
                        </select>
                    </div>

                    <div class="form-group" id="profile-city-group" style="display: none;">
                        <label for="profile-city" style="font-weight: 600;">City / Place</label>
                        <select name="city" id="profile-city">
                            <option value="">Select City</option>
                        </select>
                    </div>
                </div>

                <button type="submit" class="btn-primary" style="width: 100%; margin-top: 10px;">Save Changes</button>
            </form>
        </div>
    </div>

    <h2>👥 Joined Communities</h2>

    <% if (!user.communities || user.communities.length === 0) { %>
        <div class="empty-state">
            <span class="empty-icon">👥</span>
            <h3>No Communities Joined</h3>
            <p>You have not joined any medical support communities yet. Head over to the communities directory to find one.</p>
        </div>
    <% } else { %>
        <div style="display: flex; flex-wrap: wrap; gap: 24px; justify-content: center; margin-top: 20px; max-width: 100%;">
            <% user.communities.forEach(c => { %>
                <div class="card" style="width: 100%; max-width: 340px; margin: 0; text-align: center; display: flex; flex-direction: column; justify-content: space-between; padding: 28px; box-shadow: var(--shadow-sm); border-radius: var(--radius-lg); border: 1px solid var(--line); background: var(--surface);">
                    <div>
                        <h3 style="margin-top: 0; font-size: 1.25rem; color: var(--primary);"><%= c.name %></h3>
                        <p class="community-disease" style="margin-top: 10px; color: var(--text-secondary); font-size: 0.9rem;"><b>Target Disease:</b> <span style="background: rgba(79, 70, 229, 0.05); padding: 2px 6px; border-radius: 4px; font-weight: 600;"><%= c.disease %></span></p>
                    </div>
                    <div style="margin-top: 24px;">
                        <a href="/community/<%= c._id %>" class="btn-primary" style="display: block; text-align: center; text-decoration: none; font-size: 0.88rem; padding: 10px 16px; margin: 0;">Enter Group</a>
                    </div>
                </div>
            <% }) %>
        </div>
    <% } %>

    <!-- centered back to dashboard link -->
    <div style="text-align: center; margin-top: 40px;">
        <a href="/dashboard" class="btn-danger-outline" style="display: inline-block;">⬅ Back to Dashboard</a>
    </div>
</main>

<script>
document.addEventListener('DOMContentLoaded', function() {
    var countryEl = document.getElementById('profile-country');
    var stateEl = document.getElementById('profile-state');
    var districtEl = document.getElementById('profile-district');
    var cityEl = document.getElementById('profile-city');

    var stateGroup = document.getElementById('profile-state-group');
    var districtGroup = document.getElementById('profile-district-group');
    var cityGroup = document.getElementById('profile-city-group');

    // current user values
    var currentCountry = '<%= user.country || "" %>';
    var currentState = '<%= user.state || "" %>';
    var currentDistrict = '<%= user.district || "" %>';
    var currentCity = '<%= user.city || "" %>';

    // populate countries
    var countries = LOCATION_DATA.getCountries();
    countries.forEach(function(c) {
        var opt = document.createElement('option');
        opt.value = c;
        opt.textContent = c;
        if (c === currentCountry) opt.selected = true;
        countryEl.appendChild(opt);
    });

    // if user already has a country, populate states
    if (currentCountry && LOCATION_DATA.hasDetailedData(currentCountry)) {
        var states = LOCATION_DATA.getStates(currentCountry);
        states.forEach(function(s) {
            var opt = document.createElement('option');
            opt.value = s;
            opt.textContent = s;
            if (s === currentState) opt.selected = true;
            stateEl.appendChild(opt);
        });
        stateGroup.style.display = 'flex';

        // if user has a state, populate districts
        if (currentState) {
            var districts = LOCATION_DATA.getDistricts(currentState);
            districts.forEach(function(d) {
                var opt = document.createElement('option');
                opt.value = d;
                opt.textContent = d;
                if (d === currentDistrict) opt.selected = true;
                districtEl.appendChild(opt);
            });
            districtGroup.style.display = 'flex';

            // if user has a district, populate cities
            if (currentDistrict) {
                var cities = LOCATION_DATA.getCities(currentDistrict);
                cities.forEach(function(c) {
                    var opt = document.createElement('option');
                    opt.value = c;
                    opt.textContent = c;
                    if (c === currentCity) opt.selected = true;
                    cityEl.appendChild(opt);
                });
                cityGroup.style.display = 'flex';
            }
        }
    }

    // country change
    countryEl.addEventListener('change', function() {
        var country = this.value;
        stateEl.innerHTML = '<option value="">Select State</option>';
        districtEl.innerHTML = '<option value="">Select District</option>';
        cityEl.innerHTML = '<option value="">Select City</option>';
        districtGroup.style.display = 'none';
        cityGroup.style.display = 'none';

        if (LOCATION_DATA.hasDetailedData(country)) {
            var states = LOCATION_DATA.getStates(country);
            states.forEach(function(s) {
                var opt = document.createElement('option');
                opt.value = s;
                opt.textContent = s;
                stateEl.appendChild(opt);
            });
            stateGroup.style.display = 'flex';
        } else {
            stateGroup.style.display = 'none';
        }
    });

    // state change
    stateEl.addEventListener('change', function() {
        var state = this.value;
        districtEl.innerHTML = '<option value="">Select District</option>';
        cityEl.innerHTML = '<option value="">Select City</option>';
        cityGroup.style.display = 'none';

        if (state) {
            var districts = LOCATION_DATA.getDistricts(state);
            districts.forEach(function(d) {
                var opt = document.createElement('option');
                opt.value = d;
                opt.textContent = d;
                districtEl.appendChild(opt);
            });
            districtGroup.style.display = 'flex';
        } else {
            districtGroup.style.display = 'none';
        }
    });

    // district change
    districtEl.addEventListener('change', function() {
        var district = this.value;
        cityEl.innerHTML = '<option value="">Select City</option>';

        if (district) {
            var cities = LOCATION_DATA.getCities(district);
            cities.forEach(function(c) {
                var opt = document.createElement('option');
                opt.value = c;
                opt.textContent = c;
                cityEl.appendChild(opt);
            });
            cityGroup.style.display = 'flex';
        } else {
            cityGroup.style.display = 'none';
        }
    });
});
</script>

<%- include('partials/footer') %>