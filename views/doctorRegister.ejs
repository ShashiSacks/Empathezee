<%- include('partials/header', { title: 'Doctor Register', bodyClass: 'auth-page' }) %>

<div class="auth-container">

    <!-- LEFT SIDE (FORM AREA) -->
    <div class="auth-left" style="overflow-y: auto; padding-top: 60px; padding-bottom: 60px;">

        <h1 class="title">Doctor Register</h1>

        <form action="/api/auth/doctor/register" method="POST">

            <input type="text" name="username" placeholder="Full name" required autocomplete="name" />

            <input type="email" name="email" placeholder="Doctor email" required autocomplete="email" />

            <input type="password" name="password" placeholder="Password" required autocomplete="new-password" />

            <input type="number" name="age" placeholder="Age" min="18" max="120" />

            <label>Gender</label>
            <select name="gender" required>
                <option value="" disabled selected>Select Gender</option>
                <option value="male">Male</option>
                <option value="female">Female</option>
                <option value="other">Rather not to say</option>
            </select>

            <input type="text" name="disease" placeholder="Specialization" />

            <input type="text" name="city" placeholder="City" />

            <textarea name="bio" placeholder="Short professional bio"></textarea>

            <button type="submit">Create Doctor Account</button>

        </form>

        <p>
            Already registered?
            <a href="/doctor/login">Doctor login</a>
        </p>

        <p>
            Patient account?
            <a href="/register">Patient registration</a>
        </p>

    </div>

    <!-- RIGHT SIDE IMAGE -->
    <div class="auth-right"></div>

</div>

<%- include('partials/footer') %>
