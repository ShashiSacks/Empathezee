<!-- Hidden Google Translate element -->
<div id="google_translate_element" style="display: none;" aria-hidden="true"></div>

<script type="text/javascript">
    // Google Translate initialization
    function googleTranslateElementInit() {
        new google.translate.TranslateElement({
            pageLanguage: 'en',
            layout: google.translate.TranslateElement.InlineLayout.SIMPLE,
            autoDisplay: false
        }, 'google_translate_element');
    }

    function getLanguageFromCookie() {
        const match = document.cookie.match(/googtrans=\/en\/([^;]+)/);
        return match ? match[1] : 'en';
    }

    function changeLanguage(lang) {
        if (lang === 'en') {
            document.cookie = "googtrans=; expires=Thu, 01 Jan 1970 00:00:00 UTC; path=/;";
            document.cookie = "googtrans=; expires=Thu, 01 Jan 1970 00:00:00 UTC; path=/; domain=" + window.location.hostname;
            document.cookie = "googtrans=; expires=Thu, 01 Jan 1970 00:00:00 UTC; path=/; domain=localhost";
        } else {
            document.cookie = "googtrans=/en/" + lang + "; path=/;";
            document.cookie = "googtrans=/en/" + lang + "; path=/; domain=" + window.location.hostname;
            if (window.location.hostname === 'localhost') {
                document.cookie = "googtrans=/en/" + lang + "; path=/; domain=localhost";
            }
        }
        location.reload();
    }

    document.addEventListener('DOMContentLoaded', function() {
        const currentLang = getLanguageFromCookie();
        const selector = document.getElementById('language-selector');
        if (selector) selector.value = currentLang;

        // Newsletter button feedback
        const newsletterBtn = document.getElementById('footer-newsletter-btn');
        const newsletterInput = document.getElementById('footer-newsletter-input');
        if (newsletterBtn && newsletterInput) {
            newsletterBtn.addEventListener('click', function() {
                if (newsletterInput.value.includes('@')) {
                    newsletterBtn.innerHTML = '<i class="fa-solid fa-check"></i> Subscribed!';
                    newsletterBtn.style.background = 'var(--secondary)';
                    newsletterInput.value = '';
                    setTimeout(function() {
                        newsletterBtn.innerHTML = '<i class="fa-solid fa-paper-plane"></i> Subscribe';
                        newsletterBtn.style.background = '';
                    }, 3000);
                } else {
                    newsletterInput.focus();
                }
            });
        }
    });
</script>
<script type="text/javascript" src="//translate.google.com/translate_a/element.js?cb=googleTranslateElementInit"></script>
</body>
</html>
