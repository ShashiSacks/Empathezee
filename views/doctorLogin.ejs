<%- include('partials/header', { title: 'Doctor Login', bodyClass: 'auth-page' }) %>

<div class="auth-container">

    <!-- left side (form area) -->
    <div class="auth-left">
        <div class="auth-left-content">
            <h1 class="title">Doctor Login</h1>

            <form action="/api/auth/doctor/login" method="POST">

                <input 
                    type="email" 
                    name="email" 
                    placeholder="Doctor email" 
                    required 
                    autocomplete="email" 
                />

                <input 
                    type="password" 
                    name="password" 
                    placeholder="Password" 
                    required 
                    autocomplete="current-password" 
                />

                <button type="submit">Login as Doctor</button>

            </form>

            <p>
                Need a doctor account?
                <a href="/doctor/register">Register here</a>
            </p>

            <p>
                Patient account?
                <a href="/login">Patient login</a>
            </p>
        </div>
    </div>

    <!-- right side image -->
    <div class="auth-right"></div>

</div>

<%- include('partials/footer') %>
