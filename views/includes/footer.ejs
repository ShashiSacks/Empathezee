<footer class="main-footer" role="contentinfo">
    <div class="footer-grid">
        <!-- Brand -->
        <div class="footer-brand" style="display: flex; flex-direction: column; gap: 16px;">
            <a href="/" class="footer-logo" aria-label="Empathezee home" style="text-decoration: none; display: flex; align-items: center; gap: 10px;">
                <%- include('logo', { size: '32' }) %>
                <span style="font-size: 1.25rem; font-weight: 700; color: white;">Empathezee</span>
            </a>
            <p style="color: rgba(255,255,255,0.7); line-height: 1.6;">A premium healthcare community where people with chronic illnesses find support, doctors, and hope — together.</p>
            <div class="footer-social" aria-label="Social media links" style="display: flex; gap: 16px; margin-top: 8px;">
                <a href="#" aria-label="Twitter" style="color: rgba(255,255,255,0.7); font-size: 1.25rem; transition: color 0.2s;"><i class="fa-brands fa-x-twitter" aria-hidden="true"></i></a>
                <a href="#" aria-label="Instagram" style="color: rgba(255,255,255,0.7); font-size: 1.25rem; transition: color 0.2s;"><i class="fa-brands fa-instagram" aria-hidden="true"></i></a>
                <a href="#" aria-label="Facebook" style="color: rgba(255,255,255,0.7); font-size: 1.25rem; transition: color 0.2s;"><i class="fa-brands fa-facebook-f" aria-hidden="true"></i></a>
                <a href="#" aria-label="LinkedIn" style="color: rgba(255,255,255,0.7); font-size: 1.25rem; transition: color 0.2s;"><i class="fa-brands fa-linkedin-in" aria-hidden="true"></i></a>
            </div>
        </div>

        <!-- Platform -->
        <div style="display: flex; flex-direction: column; gap: 16px;">
            <p class="footer-heading" style="color: white; font-weight: 600; font-size: 1.1rem; margin-bottom: 8px;">Platform</p>
            <nav class="footer-links" aria-label="Platform links" style="display: flex; flex-direction: column; gap: 12px;">
                <a href="/communities" id="footer-communities" style="color: rgba(255,255,255,0.7); text-decoration: none; transition: color 0.2s;">Communities</a>
                <a href="/doctor/search" id="footer-doctors" style="color: rgba(255,255,255,0.7); text-decoration: none; transition: color 0.2s;">Find Doctors</a>
                <a href="/appointments-ui" id="footer-appointments" style="color: rgba(255,255,255,0.7); text-decoration: none; transition: color 0.2s;">Appointments</a>
                <a href="/medicine" id="footer-medicines" style="color: rgba(255,255,255,0.7); text-decoration: none; transition: color 0.2s;">Medicines</a>
                <a href="/analytics" id="footer-analytics" style="color: rgba(255,255,255,0.7); text-decoration: none; transition: color 0.2s;">Analytics</a>
            </nav>
        </div>

        <!-- Support -->
        <div style="display: flex; flex-direction: column; gap: 16px;">
            <p class="footer-heading" style="color: white; font-weight: 600; font-size: 1.1rem; margin-bottom: 8px;">Support</p>
            <nav class="footer-links" aria-label="Support links" style="display: flex; flex-direction: column; gap: 12px;">
                <a href="#" id="footer-about" style="color: rgba(255,255,255,0.7); text-decoration: none; transition: color 0.2s;">About Empathezee</a>
                <a href="#" id="footer-mental-wellness" style="color: rgba(255,255,255,0.7); text-decoration: none; transition: color 0.2s;">Mental Wellness</a>
                <a href="#" id="footer-privacy" style="color: rgba(255,255,255,0.7); text-decoration: none; transition: color 0.2s;">Privacy Policy</a>
                <a href="#" id="footer-terms" style="color: rgba(255,255,255,0.7); text-decoration: none; transition: color 0.2s;">Terms of Service</a>
                <a href="#" id="footer-contact" style="color: rgba(255,255,255,0.7); text-decoration: none; transition: color 0.2s;">Contact Us</a>
            </nav>
        </div>

        <!-- Newsletter -->
        <div style="display: flex; flex-direction: column; gap: 16px;">
            <p class="footer-heading" style="color: white; font-weight: 600; font-size: 1.1rem; margin-bottom: 8px;">Stay Updated</p>
            <p style="font-size: 0.9rem; color: rgba(255,255,255,0.7); line-height: 1.6;">Get wellness tips, community updates, and health resources delivered to your inbox.</p>
            <div class="footer-newsletter" style="display: flex; flex-direction: column; gap: 12px; margin-top: 8px;">
                <input type="email" placeholder="Your email address" id="footer-newsletter-input" aria-label="Email for newsletter" style="width: 100%; padding: 12px 16px; border-radius: 8px; border: 1px solid rgba(255,255,255,0.2); background: rgba(255,255,255,0.1); color: white; font-size: 0.95rem;">
                <button class="btn-primary" id="footer-newsletter-btn" style="width: 100%; padding: 12px; border-radius: 8px; font-weight: 600; cursor: pointer;">
                    Subscribe
                </button>
            </div>
            <!-- Emergency -->
            <div class="footer-helpline" style="margin-top: auto; padding-top: 16px; border-top: 1px solid rgba(255,255,255,0.1);" role="complementary" aria-label="Emergency helpline">
                <i class="fa-solid fa-phone" aria-hidden="true" style="color: #EF4444; margin-right: 8px;"></i>
                <span style="color: rgba(255,255,255,0.7);">Emergency Helpline:</span> <span style="color: white; font-weight: 600;">112</span>
            </div>
        </div>
    </div>

    <div class="footer-bottom" style="margin-top: 64px; padding-top: 24px; border-top: 1px solid rgba(255,255,255,0.1); display: flex; flex-direction: column; gap: 8px; align-items: center; color: rgba(255,255,255,0.5); font-size: 0.85rem; text-align: center;">
        <p>&copy; <%= new Date().getFullYear() %> Empathezee. All rights reserved. Made with 💙 for patients worldwide.</p>
        <p>Dedicated to doctor-patient support &amp; community health.</p>
    </div>
</footer>

<!-- Hidden Google Translate element -->
<div id="google_translate_element" style="display: none;" aria-hidden="true"></div>

<script type="text/javascript">
    // Google Translate initialization
    function googleTranslateElementInit() {
        new google.translate.TranslateElement({
            pageLanguage: 'en',
            layout: google.translate.TranslateElement.InlineLayout.SIMPLE,
            autoDisplay: false
        }, 'google_translate_element');
    }

    function getLanguageFromCookie() {
        const match = document.cookie.match(/googtrans=\/en\/([^;]+)/);
        return match ? match[1] : 'en';
    }

    function changeLanguage(lang) {
        if (lang === 'en') {
            document.cookie = "googtrans=; expires=Thu, 01 Jan 1970 00:00:00 UTC; path=/;";
            document.cookie = "googtrans=; expires=Thu, 01 Jan 1970 00:00:00 UTC; path=/; domain=" + window.location.hostname;
            document.cookie = "googtrans=; expires=Thu, 01 Jan 1970 00:00:00 UTC; path=/; domain=localhost";
        } else {
            document.cookie = "googtrans=/en/" + lang + "; path=/;";
            document.cookie = "googtrans=/en/" + lang + "; path=/; domain=" + window.location.hostname;
            if (window.location.hostname === 'localhost') {
                document.cookie = "googtrans=/en/" + lang + "; path=/; domain=localhost";
            }
        }
        location.reload();
    }

    document.addEventListener('DOMContentLoaded', function() {
        const currentLang = getLanguageFromCookie();
        const selector = document.getElementById('language-selector');
        if (selector) selector.value = currentLang;

        // Newsletter button feedback
        const newsletterBtn = document.getElementById('footer-newsletter-btn');
        const newsletterInput = document.getElementById('footer-newsletter-input');
        if (newsletterBtn && newsletterInput) {
            newsletterBtn.addEventListener('click', function() {
                if (newsletterInput.value.includes('@')) {
                    newsletterBtn.innerHTML = '<i class="fa-solid fa-check"></i> Subscribed!';
                    newsletterBtn.style.background = 'var(--secondary)';
                    newsletterInput.value = '';
                    setTimeout(function() {
                        newsletterBtn.innerHTML = '<i class="fa-solid fa-paper-plane"></i> Subscribe';
                        newsletterBtn.style.background = '';
                    }, 3000);
                } else {
                    newsletterInput.focus();
                }
            });
        }
    });
</script>
<script type="text/javascript" src="//translate.google.com/translate_a/element.js?cb=googleTranslateElementInit"></script>
</body>
</html>
