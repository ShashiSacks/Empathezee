<%- include('../includes/header', { title: 'Support Communities' }) %>
<%- include('../includes/navbar') %>

<main>

    <!-- Hero Banner -->
    <div style="
        background: linear-gradient(145deg, var(--primary-50) 0%, var(--accent-50) 50%, var(--secondary-50) 100%);
        padding: 64px 24px 48px;
        text-align: center;
        border-bottom: 1px solid var(--border);
        position: relative;
        overflow: hidden;
    ">
        <!-- Decorative blobs -->
        <div aria-hidden="true" style="position:absolute;top:-40px;right:-40px;width:220px;height:220px;background:radial-gradient(circle,rgba(37,99,235,0.08),transparent 70%);border-radius:50%;pointer-events:none;"></div>
        <div aria-hidden="true" style="position:absolute;bottom:-60px;left:-20px;width:200px;height:200px;background:radial-gradient(circle,rgba(20,184,166,0.07),transparent 70%);border-radius:50%;pointer-events:none;"></div>

        <div style="position:relative;z-index:2;max-width:680px;margin:0 auto;">
            <div style="
                display:inline-flex;align-items:center;gap:6px;
                padding:6px 14px;
                background:rgba(37,99,235,0.08);
                border:1px solid rgba(37,99,235,0.16);
                border-radius:999px;
                font-size:0.78rem;font-weight:600;color:var(--primary);
                margin-bottom:20px;
            ">
                <i class="fa-solid fa-heart-pulse" aria-hidden="true"></i>
                Healthcare Community Platform
            </div>

            <h1 class="title" style="font-size:clamp(2rem,4vw,2.75rem);margin-bottom:12px;">
                Find Your <span style="background:var(--grad-primary);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;">Support Community</span>
            </h1>
            <p style="color:var(--text-secondary);font-size:1rem;line-height:1.7;margin-bottom:28px;">
                Join disease-based support groups to share your journey, ask questions, and connect with people who truly understand.
            </p>

            <!-- Search Bar -->
            <div class="search-bar" style="max-width:480px;margin:0 auto;" role="search">
                <i class="fa-solid fa-magnifying-glass" style="color:var(--text-muted);" aria-hidden="true"></i>
                <input type="text" id="community-search" placeholder="Search communities, diseases..." aria-label="Search communities">
                <button class="btn-primary btn-sm" style="border-radius:999px;padding:8px 18px;" onclick="filterCommunities()" aria-label="Search">
                    Search
                </button>
            </div>
        </div>
    </div>

    <div class="page-container" style="padding-top:36px;">

        <!-- Filter Pills -->
        <div class="filter-pills" id="filter-pills" role="group" aria-label="Filter communities by disease">
            <button class="filter-pill active" data-filter="all" onclick="setFilter(this,'all')">
                <i class="fa-solid fa-border-all" aria-hidden="true"></i> All Communities
            </button>
            <button class="filter-pill" data-filter="diabetes" onclick="setFilter(this,'diabetes')">🩸 Diabetes</button>
            <button class="filter-pill" data-filter="cancer" onclick="setFilter(this,'cancer')">🎗️ Cancer</button>
            <button class="filter-pill" data-filter="heart" onclick="setFilter(this,'heart')">❤️ Heart Disease</button>
            <button class="filter-pill" data-filter="kidney" onclick="setFilter(this,'kidney')">🫘 Kidney</button>
            <button class="filter-pill" data-filter="pcos" onclick="setFilter(this,'pcos')">🌸 PCOS</button>
            <button class="filter-pill" data-filter="thyroid" onclick="setFilter(this,'thyroid')">🦋 Thyroid</button>
            <button class="filter-pill" data-filter="asthma" onclick="setFilter(this,'asthma')">💨 Asthma</button>
            <button class="filter-pill" data-filter="mental" onclick="setFilter(this,'mental')">🧠 Mental Health</button>
            <button class="filter-pill" data-filter="arthritis" onclick="setFilter(this,'arthritis')">🦴 Arthritis</button>
            <button class="filter-pill" data-filter="online" onclick="setFilter(this,'online')">
                <i class="fa-solid fa-wifi" aria-hidden="true"></i> Online
            </button>
            <button class="filter-pill" data-filter="free" onclick="setFilter(this,'free')">
                <i class="fa-solid fa-tag" aria-hidden="true"></i> Free
            </button>
        </div>

        <!-- Split Layout: List + Create Form -->
        <div class="communities-split-container" id="communities-main">

            <!-- Left: Communities List -->
            <div class="communities-left-list" id="communities-list" role="main">

                <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:4px;">
                    <h2 style="text-align:left;margin:0;font-size:1.3rem;color:var(--text);">
                        Active Support Groups
                    </h2>
                    <span id="community-count" style="font-size:0.82rem;color:var(--text-secondary);font-weight:500;"></span>
                </div>

                <% if (!communities || communities.length === 0) { %>
                    <div class="empty-state">
                        <span class="empty-icon" aria-hidden="true">👥</span>
                        <h3>No Communities Yet</h3>
                        <p>Be the first to create a support community using the form on the right!</p>
                    </div>
                <% } else { %>
                    <div id="communities-grid" style="display:flex;flex-direction:column;gap:16px;">
                        <% communities.forEach(function(c, idx) { %>
                            <%
                                const isRecommended = userDisease && c.disease.toLowerCase().includes(userDisease.toLowerCase());
                                const diseaseKey = c.disease.toLowerCase();
                                const diseaseColors = {
                                    default: { bg: 'var(--primary-50)', color: 'var(--primary)', icon: '🏥' },
                                    diabet:  { bg: '#FEF3C7', color: '#D97706', icon: '🩸' },
                                    cancer:  { bg: '#FDF2F8', color: '#9D174D', icon: '🎗️' },
                                    heart:   { bg: '#FFF1F2', color: '#BE123C', icon: '❤️' },
                                    kidney:  { bg: '#F0FDF4', color: '#166534', icon: '🫘' },
                                    pcos:    { bg: '#FDF4FF', color: '#7E22CE', icon: '🌸' },
                                    thyroid: { bg: '#FFFBEB', color: '#92400E', icon: '🦋' },
                                    asthma:  { bg: '#EFF6FF', color: '#1D4ED8', icon: '💨' },
                                    mental:  { bg: '#F5F3FF', color: '#5B21B6', icon: '🧠' },
                                    arthrit: { bg: '#FFF7ED', color: '#C2410C', icon: '🦴' },
                                    ms:      { bg: '#F0F9FF', color: '#0369A1', icon: '🔵' },
                                };
                                let colorKey = 'default';
                                for (const key of Object.keys(diseaseColors)) {
                                    if (diseaseKey.includes(key)) { colorKey = key; break; }
                                }
                                const dc = diseaseColors[colorKey];
                            %>
                            <article
                                class="card community-card <%= isRecommended ? 'highlight-card' : '' %>"
                                data-disease="<%= c.disease.toLowerCase() %>"
                                data-type="<%= c.type %>"
                                data-payment="<%= c.paymentType %>"
                                data-name="<%= c.name.toLowerCase() %>"
                                style="padding:24px;text-align:left;animation-delay:<%= idx * 0.04 %>s;"
                                aria-label="<%= c.name %> community"
                            >
                                <!-- Top Row -->
                                <div style="display:flex;align-items:flex-start;gap:16px;margin-bottom:14px;">
                                    <div class="community-card-icon" style="background:<%= dc.bg %>;color:<%= dc.color %>;flex-shrink:0;" aria-hidden="true">
                                        <%= dc.icon %>
                                    </div>
                                    <div style="flex:1;min-width:0;">
                                        <% if (isRecommended) { %>
                                            <div class="badge badge-blue" style="margin-bottom:6px;">
                                                <i class="fa-solid fa-star" aria-hidden="true"></i> Matches Your Profile
                                            </div>
                                        <% } %>
                                        <h3 style="text-align:left;font-size:1.15rem;margin:0 0 4px;color:var(--text);font-weight:700;line-height:1.3;">
                                            <%= c.name %>
                                        </h3>
                                        <p style="color:var(--text-secondary);font-size:0.875rem;margin:0;line-height:1.5;display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden;">
                                            <%= c.description %>
                                        </p>
                                    </div>
                                </div>

                                <!-- Meta Tags Row -->
                                <div style="display:flex;flex-wrap:wrap;gap:8px;margin-bottom:14px;padding-bottom:14px;border-bottom:1px solid var(--border-light);">
                                    <span class="badge badge-blue">
                                        <i class="fa-solid fa-virus" aria-hidden="true"></i>
                                        <%= c.disease %>
                                    </span>
                                    <span class="badge" style="background:var(--bg-warm);color:var(--text-secondary);border:1px solid var(--border);">
                                        <i class="fa-solid fa-location-dot" aria-hidden="true"></i>
                                        <%= c.location %>
                                    </span>
                                    <% if (c.type === 'online') { %>
                                        <span class="badge badge-green">
                                            <span class="online-dot" aria-hidden="true"></span> Online
                                        </span>
                                    <% } else { %>
                                        <span class="badge badge-orange">
                                            <i class="fa-solid fa-building" aria-hidden="true"></i> In-Person
                                        </span>
                                    <% } %>
                                    <% if (c.paymentType === 'paid') { %>
                                        <span class="badge badge-red">
                                            <i class="fa-solid fa-indian-rupee-sign" aria-hidden="true"></i>
                                            Paid — ₹<%= c.price %>
                                        </span>
                                    <% } else { %>
                                        <span class="badge badge-green">
                                            <i class="fa-solid fa-circle-check" aria-hidden="true"></i> Free
                                        </span>
                                    <% } %>
                                </div>

                                <!-- Offline Meeting Details -->
                                <% if (c.type === 'offline') { %>
                                    <div style="background:var(--warning-bg);padding:10px 14px;border-radius:var(--radius);border:1px solid rgba(245,158,11,0.2);font-size:0.8rem;margin-bottom:12px;display:flex;flex-wrap:wrap;gap:12px;">
                                        <span><i class="fa-solid fa-calendar" aria-hidden="true" style="color:var(--warning);"></i> <b>Date:</b> <%= c.meetingDate %></span>
                                        <span><i class="fa-solid fa-clock" aria-hidden="true" style="color:var(--warning);"></i> <b>Time:</b> <%= c.meetingTime %></span>
                                        <span><i class="fa-solid fa-location-dot" aria-hidden="true" style="color:var(--warning);"></i> <b>Place:</b> <%= c.meetingPlace %></span>
                                    </div>
                                <% } %>

                                <!-- Actions -->
                                <div class="community-actions" style="border-top:1px solid var(--border-light);padding-top:12px;">
                                    <% if (userCommunities.includes(c._id.toString())) { %>
                                        <div style="display:flex;gap:10px;width:100%;">
                                            <form action="/api/communities/<%= c._id %>/leave" method="POST" style="flex:1;margin:0;background:transparent;border:none;box-shadow:none;padding:0;">
                                                <button type="submit" class="btn-danger-outline btn-sm btn-block" style="font-size:0.82rem;" aria-label="Leave <%= c.name %>">
                                                    <i class="fa-solid fa-right-from-bracket" aria-hidden="true"></i> Leave
                                                </button>
                                            </form>
                                            <a href="/community/<%= c._id %>" class="btn-primary btn-sm" style="flex:1;justify-content:center;" id="enter-community-<%= c._id %>" aria-label="Enter <%= c.name %>">
                                                <i class="fa-solid fa-arrow-right" aria-hidden="true"></i> Enter Group
                                            </a>
                                        </div>
                                    <% } else { %>
                                        <form action="/api/communities/<%= c._id %>/join" method="POST" style="width:100%;margin:0;background:transparent;border:none;box-shadow:none;padding:0;">
                                            <button type="submit" class="btn-success btn-sm btn-block" style="font-size:0.85rem;" aria-label="Join <%= c.name %>">
                                                <i class="fa-solid fa-user-plus" aria-hidden="true"></i> Join Community
                                            </button>
                                        </form>
                                    <% } %>
                                </div>
                            </article>
                        <% }); %>
                    </div>

                    <!-- No results state (shown by JS) -->
                    <div id="no-results-state" class="empty-state" style="display:none;">
                        <span class="empty-icon" aria-hidden="true">🔍</span>
                        <h3>No communities found</h3>
                        <p>Try a different filter or search term, or create your own community on the right.</p>
                    </div>
                <% } %>
            </div><!-- /communities-left-list -->

            <!-- Right: Create Community Form (Sticky) -->
            <aside class="communities-right-form" id="create-community-section" aria-label="Create a new community">
                <h2 style="margin-top:0;font-size:1.2rem;font-weight:800;color:var(--text);margin-bottom:6px;text-align:center;">
                    <i class="fa-solid fa-plus-circle" style="color:var(--primary);margin-right:6px;" aria-hidden="true"></i>
                    Create Support Group
                </h2>
                <p style="text-align:center;color:var(--text-secondary);font-size:0.82rem;margin-bottom:20px;">Start a community for your condition</p>

                <form action="/api/communities" method="POST" style="gap:14px;">
                    <div class="form-group">
                        <label for="comm-name">Community Name</label>
                        <input type="text" name="name" id="comm-name" required placeholder="e.g. Diabetes Warriors India">
                    </div>
                    <div class="form-group">
                        <label for="comm-disease">Target Disease</label>
                        <input type="text" name="disease" id="comm-disease" required placeholder="e.g. Type 2 Diabetes">
                    </div>
                    <div class="form-group">
                        <label for="comm-location">Location / City</label>
                        <input type="text" name="location" id="comm-location" required placeholder="e.g. Global, Bangalore">
                    </div>
                    <div class="form-group">
                        <label for="comm-type">Meeting Format</label>
                        <select name="type" id="comm-type" required onchange="toggleEventDetails(this.value)">
                            <option value="online" selected>🌐 Online Discussion</option>
                            <option value="offline">🏢 Offline (In-Person)</option>
                        </select>
                    </div>

                    <!-- Offline details -->
                    <div id="offline-details" style="display:none;border-left:3px solid var(--warning);padding-left:14px;gap:12px;flex-direction:column;">
                        <div class="form-group">
                            <label for="comm-meetingDate">Meeting Date</label>
                            <input type="date" name="meetingDate" id="comm-meetingDate">
                        </div>
                        <div class="form-group">
                            <label for="comm-meetingTime">Meeting Time</label>
                            <input type="time" name="meetingTime" id="comm-meetingTime">
                        </div>
                        <div class="form-group">
                            <label for="comm-meetingPlace">Meeting Address</label>
                            <input type="text" name="meetingPlace" id="comm-meetingPlace" placeholder="e.g. City Hall, Room 3">
                        </div>
                    </div>

                    <div class="form-group">
                        <label for="comm-payment">Payment Access</label>
                        <select name="paymentType" id="comm-payment" required onchange="togglePrice(this.value)">
                            <option value="free" selected>🟢 Free Access</option>
                            <option value="paid">💳 Paid Entry</option>
                        </select>
                    </div>

                    <!-- Paid price -->
                    <div id="price-details" style="display:none;border-left:3px solid var(--danger);padding-left:14px;">
                        <div class="form-group">
                            <label for="comm-price">Entry Price (₹)</label>
                            <input type="number" name="price" id="comm-price" min="0" step="1" placeholder="e.g. 150">
                        </div>
                    </div>

                    <div class="form-group">
                        <label for="comm-description">Description / Guidelines</label>
                        <textarea name="description" id="comm-description" required placeholder="Describe your community goals, rules, and topics..."></textarea>
                    </div>

                    <button type="submit" class="btn-gradient btn-block" style="margin-top:4px;" id="create-community-submit">
                        <i class="fa-solid fa-rocket" aria-hidden="true"></i> Create Community
                    </button>
                </form>
            </aside>

        </div><!-- /communities-split-container -->
    </div><!-- /page-container -->
</main>

<script>
// Filter + Search Logic
const cards = Array.from(document.querySelectorAll('#communities-grid article'));
const countEl = document.getElementById('community-count');
const noResults = document.getElementById('no-results-state');

function updateCount(n) {
    if (countEl) countEl.textContent = n + ' group' + (n !== 1 ? 's' : '') + ' found';
}

let currentFilter = 'all';
let currentSearch = '';

function applyFilters() {
    let visible = 0;
    cards.forEach(function(card) {
        const disease = (card.dataset.disease || '');
        const type    = (card.dataset.type || '');
        const payment = (card.dataset.payment || '');
        const name    = (card.dataset.name || '');

        let matchFilter = true;
        if (currentFilter === 'online')   matchFilter = type === 'online';
        else if (currentFilter === 'free') matchFilter = payment === 'free';
        else if (currentFilter !== 'all') matchFilter = disease.includes(currentFilter);

        const matchSearch = currentSearch === '' ||
            disease.includes(currentSearch) ||
            name.includes(currentSearch);

        const show = matchFilter && matchSearch;
        card.style.display = show ? 'flex' : 'none';
        if (show) visible++;
    });

    updateCount(visible);
    if (noResults) noResults.style.display = visible === 0 ? 'block' : 'none';
}

function setFilter(btn, filter) {
    currentFilter = filter;
    document.querySelectorAll('.filter-pill').forEach(function(p) { p.classList.remove('active'); });
    btn.classList.add('active');
    applyFilters();
}

function filterCommunities() {
    currentSearch = (document.getElementById('community-search').value || '').toLowerCase().trim();
    applyFilters();
}

const searchInput = document.getElementById('community-search');
if (searchInput) {
    searchInput.addEventListener('input', filterCommunities);
    searchInput.addEventListener('keydown', function(e) {
        if (e.key === 'Enter') filterCommunities();
    });
}

// Initialize count
updateCount(cards.length);

// Form toggles
function toggleEventDetails(type) {
    const offlineDetails = document.getElementById('offline-details');
    const meetingDate    = document.getElementById('comm-meetingDate');
    const meetingTime    = document.getElementById('comm-meetingTime');
    const meetingPlace   = document.getElementById('comm-meetingPlace');
    if (type === 'offline') {
        offlineDetails.style.setProperty('display', 'flex', 'important');
        meetingDate.required  = true;
        meetingTime.required  = true;
        meetingPlace.required = true;
    } else {
        offlineDetails.style.setProperty('display', 'none', 'important');
        meetingDate.required  = false;
        meetingTime.required  = false;
        meetingPlace.required = false;
    }
}

function togglePrice(paymentType) {
    const priceDetails = document.getElementById('price-details');
    const price        = document.getElementById('comm-price');
    if (paymentType === 'paid') {
        priceDetails.style.display = 'block';
        price.required = true;
    } else {
        priceDetails.style.display = 'none';
        price.required = false;
    }
}
</script>

<%- include('../includes/footer') %>