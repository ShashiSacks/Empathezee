<%- include('../includes/header', { title: '404 - Page Not Found' }) %>
<%- include('../includes/navbar') %>

<main class="page-container" style="display: flex; align-items: center; justify-content: center; min-height: 70vh; text-align: center; padding: 40px 20px;">
    <div class="card" style="max-width: 500px; padding: 48px; border-radius: var(--radius-xl); box-shadow: var(--shadow-lg); background: var(--surface); border: 1.5px solid var(--line); display: flex; flex-direction: column; align-items: center; gap: 20px;">
        <span style="font-size: 4rem; margin-bottom: 10px;">🧭</span>
        <h1 style="font-family: 'Outfit', sans-serif; font-size: 3rem; font-weight: 900; color: var(--primary); margin: 0; line-height: 1; letter-spacing: -1.5px;">404</h1>
        <h2 style="font-family: 'Outfit', sans-serif; font-size: 1.5rem; font-weight: 700; color: var(--text); margin: 0;">Lost in Navigation?</h2>
        <p style="color: var(--text-secondary); font-size: 0.95rem; line-height: 1.6; margin: 0 0 10px 0;">We couldn't find the page you are looking for. It might have been moved, renamed, or perhaps it never existed.</p>
        <a href="/" class="btn-primary" style="padding: 12px 30px; font-weight: 700; text-decoration: none; border-radius: var(--radius);">Return to Dashboard</a>
    </div>
</main>

<%- include('../includes/footer') %>
