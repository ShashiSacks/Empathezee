<%- include('../includes/header', { title: 'Doctor Login', bodyClass: 'auth-page' }) %>

<div class="auth-container">

    <!-- left side (form area) -->
    <div class="auth-left">
        <div class="auth-left-content">
            <h1 class="title">Doctor Login</h1>

            <form action="/api/auth/doctor/login" method="POST">

                <input 
                    type="email" 
                    name="email" 
                    placeholder="Doctor email" 
                    required 
                    autocomplete="email" 
                />

                <input 
                    type="password" 
                    name="password" 
                    placeholder="Password" 
                    required 
                    autocomplete="current-password" 
                />

                <button type="submit">Login as Doctor</button>

            </form>

            <p>
                Need a doctor account?
                <a href="/doctor/register">Register here</a>
            </p>

            <p>
                Patient account?
                <a href="/login">Patient login</a>
            </p>
        </div>
    </div>

    <!-- right side image -->
    <div class="auth-right">
        <div class="auth-right-content-wrapper">
            <div class="auth-right-logo">
                <span class="auth-logo-icon"><i class="fa-solid fa-heart-pulse"></i></span>
                <span class="auth-logo-text">Empathezee Pro</span>
            </div>
            <h2 class="auth-right-title">Empower patients, guide support groups.</h2>
            <p class="auth-right-subtitle">Join our verified network of medical specialists. Moderate discussions, host online consultations, and help patients manage chronic conditions.</p>
            <div class="auth-right-stats">
                <div class="auth-stat-item">
                    <span class="auth-stat-num">24/7</span>
                    <span class="auth-stat-lbl">Care Guidance</span>
                </div>
                <div class="auth-stat-item">
                    <span class="auth-stat-num">15k+</span>
                    <span class="auth-stat-lbl">Patient Interactions</span>
                </div>
                <div class="auth-stat-item">
                    <span class="auth-stat-num">100%</span>
                    <span class="auth-stat-lbl">Verified Specialists</span>
                </div>
            </div>
        </div>
    </div>

</div>

<%- include('../includes/footer') %>
